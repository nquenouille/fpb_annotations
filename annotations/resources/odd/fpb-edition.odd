        <model predicate="not(following-sibling::*[not(self::lb)][1][self::add and @type='correction' and contains(xml:id, 'ta')]) and not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and descendant::lb" behaviour="inline" cssClass="underlineDotted">
                    <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. No anchor. Del of Involved Scribe without correction</desc>
            <param name="name" value="'pb-popover'"/>
