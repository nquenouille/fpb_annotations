        <model predicate="following::*[1][self::anchor[position() = 1]]" behaviour="omit">
            <desc>Omit if anchor immediately after del</desc>
        </model>
    </elementSpec>
    <elementSpec ident="birth" mode="add">
        <model predicate="./date[@when]" behaviour="inline">
            <desc>Register: Show birth dates</desc>
            <param name="content" value="if(following-sibling::death[1])then concat('(*', ./date/@when, ', ') else concat('(*', ./date/@when, ')')"/>
            <outputRendition xml:space="preserve">
            font-size: 80%;
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="occupation" mode="add">
                    <model predicate="parent::person" behaviour="omit">
                        <desc>Omit occupation in register</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="death" mode="add">
                    <model predicate="./date[@when]" behaviour="inline">
                    <desc>Register: Show death dates</desc>
            <param name="content" value="if(preceding-sibling::birth[1])then concat('✝', ./date/@when, ')') else concat('(✝', ./date/@when, ')')"/>
            <outputRendition xml:space="preserve">
            font-size: 80%;
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="closer" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
            <desc>If there are marginalia right and left after closer, set margin to element closer.</desc>
        </model>
        <model predicate="preceding::note[@place='margin-right'] and preceding::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right">
        <desc>If there are marginalia on the right before closer, set margin to element closer.</desc>
        </model>
        <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
            <desc>If there are marginalia on the right after closer, set margin to element closer.</desc>
        </model>
        <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
            <desc>If there are marginalia on the left after closer, set margin to element closer.</desc>
        </model>
        <model predicate="preceding::note[@place='margin-left']" behaviour="block" cssClass="margin-left">
        <desc>If there are marginalia on the left before closer, set margin to element closer.</desc>
        </model>
        <model predicate="preceding::note[@place='margin-right']" behaviour="block" cssClass="margin-right">
            <desc>If there are marginalia on the right before closer, set margin to element closer.</desc>
        </model>
                    <model behaviour="inline"/>
                </elementSpec>
            <elementSpec ident="opener" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after opener, set margin to element opener.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after opener, set margin to element opener.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after opener, set margin to element opener.</desc>
                    </model>
                    <model behaviour="inline">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="address" mode="add">
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-right'] and following::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after address, set margin to element address.</desc>
                    </model>
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after address, set margin to element address.</desc>
                    </model>
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after address, set margin to element address.</desc>
                    </model>
                    <model behaviour="inline">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="floatingText" mode="change">
                    <model behaviour="inline">
                    <desc>Deprecated</desc>
            <outputRendition xml:space="preserve">
            
            
                margin-left: 10em;
                margin-right: 10em;
            
            
            </outputRendition>
        </model>
                </elementSpec>
    <elementSpec ident="unclear" mode="change">
        <model predicate="not(@reason='illegible') and not(parent::del) and child::lb" behaviour="inline" cssClass="underlineDotted">
            <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. No anchor. If text unclear and not parent::del and note @type='commentary set content or if nothing set〈…〉and put popover with 'Lesart unsicher'</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="if (child::note[@type='commentary']) then replace(., child::note/text(), '') else ."/>
            <param name="alternate" value="if (child::note) then note/text() else 'Lesart unsicher.'"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'top'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="@reason='illegible' and not(parent::del) and descendant::lb" behaviour="inline" cssClass="underlineDotted">
            <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. No anchor. If text illegible and not parent::del set〈…〉and put popover with 'Unleserlich'</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="if (exists(.//lb)) then (text{'〈…〉'}, for $n in node() return if ($n/self::lb) then ($n, text{'〈…〉'}) else ()) else (text{'〈…〉'})"/>
            <param name="alternate" value="if (child::note) then note/text() else 'Unleserlich.'"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'top'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="not(@reason='illegible') and not(parent::del)" behaviour="inline" cssClass="underlineDotted">
            <desc>No line break in content. No anchor. If text unsure and not parent::del set〈…〉and put popover with 'Unsicher'</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="if (child::note[@type='commentary']) then replace(., child::note/text(), '') else ."/>
            <param name="alternate" value="if (child::note) then note/text() else 'Lesart unsicher.'"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'top'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="@reason='illegible' and not(parent::del)" behaviour="inline">
            <desc>No line break in content. No anchor. If text illegible and not parent::del set〈…〉and put popover with 'Unleserlich'</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="'〈…〉'"/>
            <param name="alternate" value="if (child::note) then note/text() else 'Unleserlich.'"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'top'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="@reason='illegible'" behaviour="inline" cssClass="underlineDotted">
            <desc>No line break in content. No anchor. If text illegible set〈…〉and put popover with 'Unleserlich' </desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="'〈…〉'"/>
            <param name="alternate" value="if (child::note) then note/text() else 'Unleserlich.'"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'top'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="not(parent::del)" behaviour="inline" cssClass="underlineDotted">
            <outputRendition xml:space="preserve" scope="after">
            content: ' 〈…〉 ';
            </outputRendition>
        </model>
                </elementSpec>
               <elementSpec ident="emph" mode="change">
                    <model behaviour="inline" cssClass="annotation annotation-emphasize">
                    <desc>letter spacing</desc>
            <outputRendition xml:space="preserve">
            letter-spacing: 3px;
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="head" mode="change">
                    <model predicate="$parameters?header='short'" behaviour="inline">
                     <desc>Short title of the document</desc>
            <param name="content" value="replace(string-join(.//text()[not(parent::ref)]), '^(.*?)[^\w]*$', '$1')"/>
        </model>
                    <model predicate="parent::figure" behaviour="block" cssClass="italic">
                    <desc>figure</desc>
                    </model>
                    <model predicate="parent::table" behaviour="inline" cssClass="italic smaller">
                     <desc>head of a table</desc>
                    </model>
                    <model predicate="parent::lg" behaviour="block" cssClass="italic">
                         <desc>Not in Use.</desc>
                    </model>
                    <model predicate="parent::list" behaviour="block" cssClass="semibold">
                         <desc>Not in Use. Head of a list.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and following::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right head">
                     <desc>If there are marginalia right and left after head, set margin to element head.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right head">
                    <desc>If there are marginalia on the right after head, set margin to element head.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left head">
                    <desc>If there are marginalia on the left after head, set margin to element head.</desc>
                    </model>
                    <model behaviour="block" cssClass="head">
                    <desc>Default in FPB</desc>
                    </model>
<!--                    <model predicate="parent::div" behaviour="heading">-->
<!--            <param name="level" value="count(ancestor::body)"/>-->
<!--        </model>-->
        <model behaviour="block"/>
                </elementSpec>
            <elementSpec ident="num" mode="add">
                    <model predicate="child::note" behaviour="inline" cssClass="underlineDotted">
                    <desc>Show note to a number as popover</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="note/node()"/>
            <param name="placement" value="'right'"/>
            <param name="fallback-placement" value="'left'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            <outputRendition xml:space="preserve">
            display: flex;
            </outputRendition>
        </model>
                </elementSpec>
            <elementSpec ident="metamark" mode="add">
                    <model behaviour="inline" cssClass="underlineDotted">
                     <desc>Missing text</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="'......'"/>
            <param name="alternate" value="'Orig. Fehlstelle'"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            <outputRendition xml:space="preserve">
            color: transparent;
            text-decoration-color: black;
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="gloss" mode="add">
                    <model predicate="@type='margin-right'" behaviour="inline">
                    <desc>Show gloss on the right</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
                display: block;
                float: right;
                margin-right: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: right;
                overflow: visible;
                font-size: 70%;
                text-align: right;
                text-indent: 0%;
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="@type='margin-left'" behaviour="inline">
                    <desc>Show gloss on the right</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
                display: block;
                float: left;
                margin-left: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: left;
                overflow: visible;
                font-size: 70%;
                text-align: left;
                text-indent: 0%;
            
            
            
            
            
            </outputRendition>
        </model>
                </elementSpec>
            <elementSpec ident="ab" mode="change">
                <model predicate="@type='hidden'" behaviour="alternate" cssClass="underlineDotted">
                <desc>Non-edited text</desc>
                    <param name="default" value="."/>
                    <param name="alternate" value="'Non-edited text / Nicht edierter Text'"/>
                    <outputRendition xml:space="preserve">
                    color: transparent;
                    </outputRendition>
                </model>
                <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="paragraph" cssClass="margin-left margin-right">
            <desc>Deprecated. If there are marginalia right and left after ab, set margin to element ab.</desc>
        </model>
        <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="paragraph" cssClass="margin-right">
            <desc>Deprecated. If there are marginalia on the right after ab, set margin to element ab.</desc>
        </model>
        <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="paragraph" cssClass="margin-left">
            <desc>Deprecated. If there are marginalia on the left after ab, set margin to element ab.</desc>
        </model>
        <model behaviour="inline">
            <desc>Default</desc>
        </model>
                </elementSpec>
            <elementSpec ident="table" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="table" cssClass="margin-left margin-right table smaller">
                        <desc>If there are marginalia right and left after table, set margin to element table.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="table" cssClass="margin-right table smaller">
                        <desc>If there are marginalia on the right after table, set margin to element table.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="table" cssClass="margin-left table smaller">
                        <desc>If there are marginalia on the left after table, set margin to element table.</desc>
                    </model>
                    <model predicate="@rendition='stundenplan'" behaviour="table" cssClass="smaller stundenplan-table">
                        <desc>Table for time tables</desc>
                    </model>
                    <model behaviour="table" cssClass="smaller"/>
                </elementSpec>
                
        <elementSpec ident="cell" mode="change">
                    <model predicate="@role='subheading' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan center">
                    <desc>Subheading for time table cell</desc>
        </model>
                    <model predicate="@role='subheading'" behaviour="cell" cssClass="italic center">
                    <desc>Subheading for table cell</desc>
        </model>
                    <model predicate="@role='heading' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan semibold center">
                        <desc>Heading for time table cell</desc>
                    </model>
                    <model predicate="@role='heading'" behaviour="cell" cssClass="semibold center">
                    <desc>Heading for cell</desc>
                    </model>
                    <model predicate="@role='unedited' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan center">
                    <desc>Unedited cells for time table</desc>
            <outputRendition xml:space="preserve">
            background-color: #e6e6e6;
            </outputRendition>
        </model>
                    <model predicate="@role='unedited'" behaviour="cell" cssClass="semibold center">
                    <desc>Unedited cells for table</desc>
            <outputRendition xml:space="preserve">
            background-color: #e6e6e6;
            </outputRendition>
        </model>
                    <model predicate="@rendition='stundenplan-left-bottom-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-left-hidden stundenplan-bottom-hidden">
                    <desc>Hide left and bottom line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan-left-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-left-hidden">
                    <desc>Hide left line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan-bottom-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-bottom-hidden">
                    <desc>Hide bottom line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan'" behaviour="cell" cssClass="stundenplan">
                    <desc>Default for time table cell</desc>
                    </model>
                    <model behaviour="cell">
                    <desc>Default for table cell</desc>
                    </model>
                </elementSpec>
        <elementSpec ident="title" mode="change">
                    <model behaviour="paragraph">
                    <desc>Not in use. Title</desc>
                        <outputRendition xml:space="preserve">
                            font-weight: bold;
                        </outputRendition>
                    </model>
                </elementSpec>
        <elementSpec ident="geo" mode="change">
            <modelSequence>
                <model output="web" predicate="$parameters?view='map'" behaviour="webcomponent">
                <desc>Show coordinates in map container</desc>
                    <param name="name" value="'pb-geolocation'"/>
                    <param name="latitude" value="tokenize(., ' ')[1]"/>
                    <param name="longitude" value="tokenize(., ' ')[2]"/>
                    <param name="content" value="."/>
                    <param name="emit" value="'map'"/>
                    <outputRendition xml:space="preserve">
                    
                    color: #1565c0;
                    cursor: pointer;
                    position: absolute;
                    
                    </outputRendition>
                </model>
                <model behaviour="inline"/>
            </modelSequence>
        </elementSpec>
        <elementSpec ident="ptr" mode="change">
            <model predicate="parent::notatedMusic" behaviour="pass-through">
                <desc>Load and display external MEI</desc>
                <param name="url" value="@target"/>
                <pb:template xmlns="" xml:space="preserve"><pb-mei url="[[url]]" player="player">
                </pb-mei></pb:template>
            </model>
        </elementSpec>
        <elementSpec ident="notatedMusic" mode="change">
        <modelSequence>
            <model predicate=".//label" behaviour="heading">
                <param name="content" value=".//label"/>
                <param name="level" value="5"/>
            </model>
            <model behaviour="figure">
                <param name="content" value="(ptr, mei:mdiv)"/>
            </model>
        </modelSequence>
        </elementSpec>
        <elementSpec ident="mei:mdiv" mode="change">
        <model behaviour="pass-through">
            <desc>Single MEI mdiv needs to be wrapped to create complete MEI document</desc>
            <param name="data" value="let $title := root($parameters?root)//titleStmt/title let $data :=   &lt;mei xmlns=&#34;http://www.music-encoding.org/ns/mei&#34; meiversion=&#34;5.1.0&#34;&gt;     &lt;meiHead&gt;         &lt;fileDesc&gt;             &lt;titleStmt&gt;                 &lt;title&gt;&lt;/title&gt;             &lt;/titleStmt&gt;             &lt;pubStmt&gt;&lt;/pubStmt&gt;         &lt;/fileDesc&gt;     &lt;/meiHead&gt;     &lt;music&gt;         &lt;body&gt;{.}&lt;/body&gt;     &lt;/music&gt;   &lt;/mei&gt; return   serialize($data)"/>
            <pb:template xmlns="" xml:space="preserve"><pb-mei player="player" data="[[data]]"/></pb:template>
        </model>
    </elementSpec>
            </schemaSpec>
        </body>
    </text>
</TEI>