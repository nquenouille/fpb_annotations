    <text xmlns="http://www.tei-c.org/ns/1.0">
        <body>
            <schemaSpec start="TEI teiCorpus" ident="FPB-Edition" source="teipublisher.odd"> 
                <elementSpec ident="hi" mode="change">
                    <modelSequence>
            <model predicate="@rend=&#34;superscript&#34;" behaviour="inline">
                <desc>For @rend='superscript' display the text in superscript.</desc>
                <outputRendition xml:space="preserve">
                
                            vertical-align: super;
                            font-size: 50%;
                        
                </outputRendition>
            </model>
            <model predicate="@rend=&#34;underline&#34;" behaviour="inline" cssClass="underline">
                <desc>For @rend='underline' display the text with an underline.</desc>
            </model>
            <model predicate="@rend='semibold'" behaviour="inline" cssClass="semibold">
                <desc>For @rend='semibold' display the text, if possible in semi-bold, otherwise in bold.</desc>
            </model>
            <model predicate="@rend=&#34;latintype&#34; or @rend=&#34;italic&#34;" behaviour="inline" cssClass="italic">
                <desc>For @rend='latintype' or @rend='italic' put the text, which in original is written in Latinscript, in italics.</desc>
            </model>
        </modelSequence>
                </elementSpec>
                <elementSpec ident="choice" mode="change">
                    <model predicate="sic and corr and descendant::lb" behaviour="inline" cssClass="underlineDotted">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. In the case of an unusual spelling or similar, the correct spelling is displayed by a mouseover. The word in question is marked with a dotted line.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="sic[1]"/>
            <param name="alternate" value="concat('recte: ', corr[1])"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model predicate="sic and corr" behaviour="inline" cssClass="underlineDotted">
            <desc>Content without line break: In the case of an unusual spelling or similar, the correct spelling is displayed by a mouseover. The word in question is marked with a dotted line.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="sic[1]"/>
            <param name="alternate" value="concat('recte: ', corr[1])"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model predicate="abbr and expan and descendant::lb" behaviour="inline" cssClass="underlineDotted">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Normal use of abbreviation and expansion: The text will preserve the abbreviation, and the mouse-over shows the expansion. The word in question is marked with a dotted line.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="abbr[1]"/>
            <param name="alternate" value="expan[1]"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model predicate="abbr and expan" behaviour="inline" cssClass="underlineDotted">
            <desc>Content without line break: Normal use of abbreviation and expansion: The text will preserve the abbreviation, and the mouse-over shows the expansion. The word in question is marked with a dotted line.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="abbr[1]"/>
            <param name="alternate" value="expan[1]"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model predicate="orig and reg and descendant::lb" behaviour="inline" cssClass="underlineDotted">
            <desc>Not in use. Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Not in use.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="reg[1]"/>
            <param name="alternate" value="orig[1]"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="orig and reg" behaviour="inline" cssClass="underlineDotted">
            <desc>Not in use. Content without line break.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="reg[1]"/>
            <param name="alternate" value="orig[1]"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model> 
                </elementSpec>
                <elementSpec ident="dateline" mode="change">
                    <model behaviour="block">
            <desc>Datelines will be rendered as block.</desc>
        </model>
                </elementSpec>
                <elementSpec ident="date" mode="change">
                    <model output="web" predicate="@when and descendant::lb and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Mouseover for specific dates with attribute @when. Case distinction for complete information (YYYY-MM-DD) and partial information (YYYY; YYYY-MM; YYYY-DD; MM; MM-DD; DD) and month mapping.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value=" let $date-pattern := matches(@when, '^\d{4}-\d{2}-\d{2}$') let $month-pattern := matches(@when, '^\d{4}-\d{2}$') let $month-day-pattern := matches(@when, '^--\d{2}-\d{2}$') let $year-only-pattern := matches(@when, '^\d{4}$') let $day-only-pattern := matches(@when, '^---\d{2}$') let $month-only-pattern := matches(@when, '^--\d{2}$') let $months := ('Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember') return if ($date-pattern) then let $month := substring(@when, 6, 2) let $month-index := xs:int($month) let $day := substring(@when, 9, 2) let $year := substring(@when, 1, 4) return concat($day, '. ', $months[$month-index], ' ', $year) else if ($month-pattern) then let $month := substring(@when, 6, 2) let $month-index := xs:int($month) let $year := substring(@when, 1, 4) return concat($months[$month-index], ' ', $year) else if ($month-day-pattern) then let $month := substring(@when, 3, 2) let $month-index := xs:int($month) let $day := substring(@when, 6,2) return concat($day, '. ', $months[$month-index]) else if ($day-only-pattern) then let $day := substring(@when, 4, 2) return concat($day, '. Tag eines unbekannten Monats') else if ($month-only-pattern) then let $month := substring(@when, 3, 2) let $month-index := xs:int($month) return $months[$month-index] else if ($year-only-pattern) then let $year := substring(@when, 1, 4) return $year else ()"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model output="web" predicate="@when and not(descendant::lb)" behaviour="inline" cssClass="underlineDotted">
            <desc>Content without line break: Mouseover for specific dates with attribute @when. Case distinction for complete information (YYYY-MM-DD) and partial information (YYYY; YYYY-MM; YYYY-DD; MM; MM-DD; DD) and month mapping.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value=" let $date-pattern := matches(@when, '^\d{4}-\d{2}-\d{2}$') let $month-pattern := matches(@when, '^\d{4}-\d{2}$') let $month-day-pattern := matches(@when, '^--\d{2}-\d{2}$') let $year-only-pattern := matches(@when, '^\d{4}$') let $day-only-pattern := matches(@when, '^---\d{2}$') let $month-only-pattern := matches(@when, '^--\d{2}$') let $months := ('Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember') return if ($date-pattern) then let $month := substring(@when, 6, 2) let $month-index := xs:int($month) let $day := substring(@when, 9, 2) let $year := substring(@when, 1, 4) return concat($day, '. ', $months[$month-index], ' ', $year) else if ($month-pattern) then let $month := substring(@when, 6, 2) let $month-index := xs:int($month) let $year := substring(@when, 1, 4) return concat($months[$month-index], ' ', $year) else if ($month-day-pattern) then let $month := substring(@when, 3, 2) let $month-index := xs:int($month) let $day := substring(@when, 6,2) return concat($day, '. ', $months[$month-index]) else if ($day-only-pattern) then let $day := substring(@when, 4, 2) return concat($day, '. Tag eines unbekannten Monats') else if ($month-only-pattern) then let $month := substring(@when, 3, 2) let $month-index := xs:int($month) return $months[$month-index] else if ($year-only-pattern) then let $year := substring(@when, 1, 4) return $year else ()"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model output="web" predicate="@from and @to and descendant::lb and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Mouseover for case of attributes @from and @to.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="concat(@from, ' bis ', @to)"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model output="web" predicate="@from and @to and not(descendant::lb)" behaviour="inline" cssClass="underlineDotted">
            <desc>Content without line break: Mouseover for case of attributes @from and @to.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="concat(@from, ' bis ', @to)"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model output="web" predicate="@from and not(@to) and descendant::lb  and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Mouseover for case of attributes @from without specific ending.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="concat('Von ', @from, ' an.')"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model output="web" predicate="@from and not(@to) and not(descendant::lb)" behaviour="inline" cssClass="underlineDotted">
            <desc>Content without line break: Mouseover for case of attributes @from without specific ending.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="concat('Von ', @from, ' an.')"/>
            <param name="placement" value="'bottom'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model behaviour="inline">
            <desc>Default.</desc>
            <outputRendition xml:space="preserve">
            null
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="persName" mode="add">
                    <model output="web" predicate="$parameters?view='persons'" behaviour="listItem">
            <desc>Edition View: Highlight person's name in view='persons' list.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb:template>
            <outputRendition xml:space="preserve">
            
                        font-size: 12pt;
                        pb-highlight-color: #ffff00;
                        
            </outputRendition>
        </model>
                    
                    <model output="web" predicate="@ref" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>Edition View: Highlight persons in text.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ffff00;
            </outputRendition>
        </model>
                    <model behaviour="inline">
            <desc>Default.</desc>
        </model>
                </elementSpec>
                <elementSpec ident="person" mode="add">
                    <model output="web" predicate="@xml:id" behaviour="listItem">
            <desc>Not in use. Edition View: Highlight person in list.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@xml:id"/>
            <pb:template xmlns="" xml:space="preserve"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb:template>
        </model>
                    <model behaviour="block">
            <desc>Default.</desc>
        </model>
                </elementSpec>
                <elementSpec ident="place" mode="add">
                    <model behaviour="block">
            <desc>Not in use. Edition View: Display note to place.</desc>
            <param name="content" value="note/node()"/>
        </model>
                </elementSpec>
                <elementSpec ident="placeName" mode="add">
                    <model output="web" predicate="$parameters?view='places'" behaviour="listItem">
            <desc>Edition View: Highlight places in view='places' and connect to map via geolocation in diplomatic view.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="content" value="."/>
            <param name="longitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lng := substring-after($geo, ' ')  return $lng"/>
            <param name="latitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') return $lat"/>
            <param name="label" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() return $name"/>
            <pb:template xmlns="" xml:space="preserve"><pb-geolocation longitude="[[longitude]]" latitude="[[latitude]]" label="[[label]]"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb-geolocation></pb:template>
            <outputRendition xml:space="preserve">
            
                        font-size: 12pt;
                        pb-highlight-color: #ffff00;
                        
            </outputRendition>
        </model>
                    <model output="web" predicate="@ref and $parameters?mode='normalized'" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>Edition View: Highlight places and connect to map via geolocation in normalized view.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="longitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lng := substring-after($geo, ' ')  return $lng"/>
            <param name="latitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') return $lat"/>
            <param name="label" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() return $name"/>
            <pb:template xmlns="" xml:space="preserve">
                              <pb-geolocation xmlns="http://www.tei-c.org/ns/1.0" longitude="[[longitude]]" latitude="[[latitude]]" label="[[label]]">[[content]]</pb-geolocation>
                          </pb:template>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ffff00;
            </outputRendition>
        </model>
                    <model output="web" predicate="@ref" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>Edition View: Highlight places' and connect to map via geolocation.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="longitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lng := substring-after($geo, ' ')  return $lng"/>
            <param name="latitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') return $lat"/>
            <param name="label" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() return $name"/>
            <pb:template xmlns="" xml:space="preserve">
                              <pb-geolocation xmlns="http://www.tei-c.org/ns/1.0" longitude="[[longitude]]" latitude="[[latitude]]" label="[[label]]">[[content]]</pb-geolocation>
                          </pb:template>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ffff00;
            </outputRendition>
        </model>
                    <model behaviour="inline">
            <desc>Default.</desc>
        </model>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="rs" mode="add">
                    <model output="web" predicate="@type='place' and $parameters?view='places'" behaviour="listItem">
            <desc>Edition view: Highlight referred place in view='places' in diplomatic text.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb:template>
            <outputRendition xml:space="preserve">
            
                        font-size: 12pt;
                        pb-highlight-color: #ffff00;
                        
            </outputRendition>
        </model>
                    <model output="web" predicate="@type='place' and @ref" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>Edition view: Highlight referred place and connect to map via geolocation.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="longitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lng := substring-after($geo, ' ')  return $lng"/>
            <param name="latitude" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') return $lat"/>
            <param name="label" value="let $place := id(@ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() return $name"/>
            <pb:template xmlns="" xml:space="preserve">
                              <pb-geolocation xmlns="http://www.tei-c.org/ns/1.0" longitude="[[longitude]]" latitude="[[latitude]]" label="[[label]]">[[content]]</pb-geolocation>
                          </pb:template>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ffff00;
            </outputRendition>
        </model>
                    <model output="web" predicate="@type='person' and $parameters?view='persons'" behaviour="listItem">
            <desc>Edition view: Highlight referred persons in view='persons' in diplomatic view.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb:template>
            <outputRendition xml:space="preserve">
            
                        font-size: 12pt;
                        pb-highlight-color: #ffff00;
                        
            </outputRendition>
        </model>
                    <model output="web" predicate="@type='person' and @ref" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>Edition view: Highlight referred persons in text in diplomatic view.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@ref"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ffff00;
            </outputRendition>
        </model>
                </elementSpec>
                    
        <elementSpec ident="note" mode="change">
                    <model predicate="@type='unedited'" behaviour="inline" cssClass="underlineDotted">
            <desc>If there is unedited text, show only [...] with grey background and the note text as mouseover (normally "unedited text" or similar).</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="'[...]'"/>
            <param name="alternate" value="."/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            <outputRendition xml:space="preserve">
                background-color: #e6e6e6;
            </outputRendition>
        </model>
                    <model predicate="@place='margin-left'" behaviour="inline">
            <desc>If note is type='marginalia' and placed 'margin-left' show note on the left and give some space.</desc>
            <param name="content" value="for $anchor in ..//anchor/@xml:id return root($parameters?root)//div//note[@type='marginalia'][@target=$anchor]/node()"/>
            <outputRendition xml:space="preserve">
            
            
            
            
            
                display: block;
                float: right;
                margin-right: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: right;
                overflow: visible;
                font-size: 70%;
                text-align: right;
                text-indent: 0%;
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="@place='margin-right'" behaviour="inline">
            <desc>If note is type='marginalia' and placed 'margin-right' show note on the left and give some space.</desc>
            <param name="content" value="for $anchor in ..//anchor/@xml:id return root($parameters?root)//div//note[@type='marginalia'][@target=$anchor]/node()"/>
            <outputRendition xml:space="preserve">
            
            
            
            
            
                display: block;
                float: left;
                margin-left: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: left;
                overflow: visible;
                font-size: 70%;
                text-align: left;
                text-indent: 0%;
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="(@place='top' or @place='bottom') and following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="paragraph" cssClass="margin-left margin-right smaller">
            <desc>If there are marginalia right and left, set margin to main text.</desc>
        </model>
                    <model predicate="(@place='top' or @place='bottom') and following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="paragraph" cssClass="margin-right smaller">
            <desc>If there are marginalia on the right, set margin to main text.</desc>
        </model>
                    <model predicate="(@place='top' or @place='bottom') and following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="paragraph" cssClass="margin-left smaller">
            <desc>If there are marginalia on the left, set margin to main text.</desc>
        </model>
                    <model output="web" predicate="@type='commented'" behaviour="webcomponent" cssClass="underlineDashed">
            <desc>If note is a commentary, get commentary and show it in mouseover.</desc>
            <param name="content" value="."/>
            <param name="name" value="'pb-highlight'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="concat('#', child::anchor/@xml:id)"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <outputRendition xml:space="preserve">
            pb-highlight-color: #ccfff5;
            </outputRendition>
        </model>
                    <model output="web" predicate="@type='note' and $parameters?view='notes'" behaviour="listItem">
            <desc>Edition view: If there is a commentary, show it in the view='notes'.</desc>
            <param name="name" value="'pb-highlight'"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="key" value="@target"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve"><pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">[[content]]</pb-highlight></pb:template>
            <outputRendition xml:space="preserve">
            
                        font-size: 12pt;
                        pb-highlight-color: #ccfff5;
                        
            </outputRendition>
        </model>
                    <model predicate="@type='presentation' and descendant::lb and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted grey">
            <desc>Edition / Diplomatic View: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. If there is a presentation note, show in mouseover, which kind of note, and who left it.</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="if(contains(@hand, 'main')) then concat('Präsentationsvermerk, ergänzt von: ', replace(@hand, 'main', 'Unbekannter Hauptschreiber ')) else if(contains(@hand, 'involved')) then concat('Präsentationsvermerk, ergänzt von: ', replace(@hand, 'involved', 'Unbekannter Schreiber ')) else if(@subtype='person' and starts-with(@hand, 'fpb-')) then concat('Präsentationsvermerk, ergänzt von: ', id(@hand, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/persName/text()) else concat('Präsentationsvermerk, ergänzt von: ', ./@hand)"/>
            <param name="placement" value="'left'"/>
            <param name="fallback-placement" value="'right'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover xmlns="http://www.tei-c.org/ns/1.0" placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
                    <model predicate="@type='presentation' and not(descendant::lb)" behaviour="inline" cssClass="underlineDotted grey">
