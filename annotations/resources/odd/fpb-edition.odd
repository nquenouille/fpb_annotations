            <pb:template xmlns="" xml:space="preserve"><pb-popover xmlns="http://www.tei-c.org/ns/1.0" placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
