                    <model predicate="parent::person" behaviour="omit">
            <desc>Not in use. If note is a part of person in register, omit. The child::note will be omitted here, because it is taken care of at ident="person".</desc>
        </model>
                    <model predicate="parent::num" behaviour="omit">
            <desc>Not in use. If there is a number, the child::note will be omitted here, because it is taken care of at ident="num".</desc>
        </model>
                    <model predicate="parent::span" behaviour="omit">
            <desc>Not in use. If there is a span with child::note, omit.</desc>
        </model>
                    <model predicate="$parameters?view='notes' and not(parent::unclear)" behaviour="listItem">
            <desc>If there is a commentary that does not have a parent::unclear, show it in view='notes' as list item.</desc>
            <param name="n" value="@n"/>
        </model>
                    <model predicate="not(parent::unclear)" behaviour="inline"/>
                    <model behaviour="block"/>
                </elementSpec>
                <elementSpec ident="teiHeader" mode="change">
                    <desc>Heading behaiour in latex output.</desc>
                    <model output="latex" behaviour="block">
            <param name="content" value=".//fileDesc//sourceDesc"/>
        </model>
                    <modelSequence output="fo">
            <desc>Heading behaiour in FO output.</desc>
            <model behaviour="heading">
                <param name="content" value="fileDesc/titleStmt/title[@xml:lang='de']/text()"/>
                <param name="level" value="1"/>
            </model>
            <model behaviour="heading">
                <param name="content" value="'Metadata'"/>
                <param name="level" value="2"/>
            </model>
            <model behaviour="block">
                <param name="content" value=".//sourceDesc//msContents"/>
            </model>
        </modelSequence>
                    <model predicate="$parameters?view='metadata'" behaviour="block" cssClass="metadata">
            <desc>Heading for metadata output in view='metadata'.</desc>
            <param name="content" value=".//fileDesc//sourceDesc | .//fileDesc//publicationStmt |.//profileDesc//correspDesc"/>
            <outputRendition xml:space="preserve">
            font-size: .75em;
            </outputRendition>
        </model>
                    <model output="web" predicate="$parameters?header='short'" behaviour="block">
            <desc>Edition view: Show short header.</desc>
        </model>
                    <model output="fo" behaviour="omit">
            <desc>Omit FO output here.</desc>
        </model>
                    <model predicate="$parameters?header='letter'" behaviour="inline">
            <desc>Edition view: Show title as header.</desc>
            <param name="content" value="./fileDesc/titleStmt/title[@xml:lang='de']"/>
            <param name="level" value="5"/>
        </model>
                </elementSpec>
                <elementSpec ident="orig" mode="change">
                    <model predicate="@rend='indent'" behaviour="inline" cssClass="indentation">
            <desc>Original indentation.</desc>
        </model>
                    <model predicate="@rend='keepLB' and $parameters?mode='normalized'" behaviour="break">
            <desc>Original line breaks should be kept.</desc>
            <param name="type" value="'line'"/>
        </model>
        <model predicate="@rend='keepLB' and $parameters?mode='diplomatic'" behaviour="break">
            <desc>Original line breaks should be kept.</desc>
            <param name="type" value="'line'"/>
        </model>
                    <model behaviour="inline" useSourceRendition="true">
            <desc>Default.</desc>
        </model>
                </elementSpec>
                <elementSpec ident="anchor" mode="change">
                    <modelSequence>
            <model predicate="contains(@xml:id, 'm') and following::note[@place='margin-left']" behaviour="inline">
                <desc>Place marginalia to the left of the text, if margin-left note.</desc>
                <param name="content" value="for $anchor in ./@xml:id return root($parameters?root)//div//note[@type='marginalia'][@place='margin-left'][@target=$anchor]/node()"/>
                <outputRendition xml:space="preserve">
                
            
            
            
            
                display: block;
                float: left;
                margin-left: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: right;
                overflow: visible;
                font-size: 70%;
                text-align: left;
                text-indent: 0%;
            
            
            
            
            
                </outputRendition>
            </model>
            <model predicate="contains(@xml:id, 'm') and following::note[@place='margin-right']" behaviour="inline">
                <desc>Place marginalia to the right of the text, if margin-right note.</desc>
                <param name="content" value="for $anchor in ./@xml:id return root($parameters?root)//div//note[@type='marginalia'][@place='margin-right'][@target=$anchor]/node()"/>
                <outputRendition xml:space="preserve">
                
            
            
            
            
                display: block;
                float: right;
                margin-right: -15%;
                width: 5em;
                margin-bottom: 0;
                margin-top: 0;
                clear: left;
                overflow: visible;
                font-size: 70%;
                text-align: right;
                text-indent: 0%;
            
            
            
            
            
                </outputRendition>
            </model>
            <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='addition']/@xml:id) and not((concat('t', ./@xml:id) = root($parameters?root)//add[@type='addition'][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id))" behaviour="inline" cssClass="underlineDotted">
                <desc>add[addition] with Involved Scribe</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="id(concat('t', @xml:id), root($parameters?root))[@type='addition']/node()"/>
                <param name="alternate" value="let $root := root($parameters?root), $id := concat('t', @xml:id), $add := $root//add[@type='addition'][@xml:id=$id], $hand := $add/@hand, $name := if(starts-with($hand,'fpb-')) then $add/id($hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName/text() else if($hand) then replace($hand,'involved','Unbekannter Schreiber ') else () return concat('Ergänzt von: ',$name)"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='addition']/@xml:id) and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='addition'][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id)" behaviour="inline" cssClass="underlineDotted">
                <desc>add[addition] with Main Scribe</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="if (id(concat('t', @xml:id), root($parameters?root))[@type='addition'] and count(id(concat('t', @xml:id), root($parameters?root))[@type='addition']/del) = 1 and count(id(concat('t', @xml:id), root($parameters?root))[@type='addition']/node()[not(self::del) and normalize-space() != '']) = 0) then '〈…〉' else id(concat('t', @xml:id), root($parameters?root))[@type='addition']/node()"/>
                <param name="alternate" value="let $root := root($parameters?root), $id := concat('t', @xml:id), $add := $root//add[@type='addition'][@xml:id=$id], $hand := $add/@hand, $name := if(starts-with($hand,'fpb-')) then $add/id($hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName/text() else if($hand) then replace($hand,'main','Unbekannter Hauptschreiber ') else () return concat('Ergänzt von: ', $name)"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id) and not((concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id)) and preceding::del[1]/descendant::lb" behaviour="inline" cssClass="underlineDotted">
                <desc>Line break in content: add[correction] with Involved Scribe. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="preceding::del[1]/node()"/>
                <param name="alternate" value="let $main := id(concat('t', @xml:id), root($parameters?root)), $del := ./preceding::del[1]  return                                              string-join(                                               for $a in ($main, $main/child::add)                                               let $hand :=                                                  if($a/@hand) then                                                   if(starts-with($a/@hand, 'fpb-')) then                                                     string($a/id(@hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName)                                                   else                                                     replace($a/@hand, 'involved', 'Unbekannter Schreiber ')                                                 else 'Unbekannter Schreiber'                                               let $delText := string-join($a/node()[not(self::add)], '')                                                                                            let $new := string-join($a/node()[not(self::add)], '')                                               let $status := if($del/unclear[@reason='unsure']) then ' (unsicher)' else if ($del/unclear[@reason='illegible']) then ' (unleserlich)' else ''                                               return concat('Korrigiert von: ', $hand, ' zu: ', $new, $status)                                             , '; ')"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id) and not((concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id)) and not(preceding::del[1]/descendant::lb)" behaviour="inline" cssClass="underlineDotted">
                <desc>No line break in content: add[correction] with Involved Scribe.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="preceding::del[1]/node()"/>
                <param name="alternate" value="let $main := id(concat('t', @xml:id), root($parameters?root)), $del := ./preceding::del[1]  return                                              string-join(                                               for $a in ($main, $main/child::add)                                               let $hand :=                                                  if($a/@hand) then                                                   if(starts-with($a/@hand, 'fpb-')) then                                                     string($a/id(@hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName)                                                   else                                                     replace($a/@hand, 'involved', 'Unbekannter Schreiber ')                                                 else 'Unbekannter Schreiber'                                               let $delText := string-join($a/node()[not(self::add)], '')                                                                                            let $new := string-join($a/node()[not(self::add)], '')                                               let $status := if($del/unclear[@reason='unsure']) then ' (unsicher)' else if ($del/unclear[@reason='illegible']) then ' (unleserlich)' else ''                                               return concat('Korrigiert von: ', $hand, ' zu: ', $new, $status)                                             , '; ')"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="contains(@xml:id,'a') and concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and ((@hand) and (starts-with(@hand,'main') or starts-with(@hand,'fpb-')))]/@xml:id)" behaviour="inline" cssClass="underlineDotted">
                <desc>add[correction] with Main Scribe</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="let $add := id(concat('t', @xml:id), root($parameters?root))                                            return                                              if ($add//add[@type='correction'])                                              then $add//add[@type='correction'][last()]/node()                                              else $add/node()"/>
                <param name="alternate" value="let $root := root($parameters?root) let $add := id(concat('t', @xml:id), $root), $del := ./preceding::del[1]     let $delText :=     string-join(         for $n in $del/node()         return             typeswitch($n)                  case element(lb)                     return '&#xA;'                  case element(span)                     return                         if ($n/@type = 'hyphen')                         then ''                         else string($n)                 case element(choice)                     return                         concat($n/abbr, ' (= ', $n/expan,') ')                 case element(unclear)                     return                         if($n/@reason = 'unsure')                              then concat(string($n), ' (unsicher) ')                         else if($n/@reason = 'illegible')                             then concat(string($n), ' (unleserlich) ')                         else ()                 case text()                     return string($n)                  default                     return string($n)     ,'')  let $chain :=     if ($add//add[@type='correction']) then ($add, $add//add[@type='correction'])     else ($add)  return string-join(     for $i in 1 to count($chain)     let $a := $chain[$i]     let $hand :=         if ($a/@hand) then             if (starts-with($a/@hand,'fpb-')) then                 string($a/id(@hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName)             else replace($a/@hand,'main','Unbekannter Hauptschreiber ')         else 'Unbekannter Hauptschreiber' return         if (count($chain)=1) then             normalize-space(concat(                 'Korrigiert von: ', $hand, '; ',                 'Ursprüngliche Lesart: ', $delText))         else             normalize-space(concat(                 'Korrigiert von: ', $hand, '; ',                 'Ursprüngliche Lesart ', $i, ': ', $delText)             ) , '; ')"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
        </modelSequence>
        </elementSpec>
        <elementSpec ident="term" mode="add">
            <model predicate="@type='term' and descendant::lb and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted">
                <desc>Not in use. Line break in content: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(@type='term') then let $s := id(@key, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/def/string() return concat(id(@key, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/orth/term/string(), ': ', $s) else ()"/>
                <param name="placement" value="'bottom'"/>
                <param name="fallback-placement" value="'top'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="@type='term'" behaviour="inline" cssClass="underlineDotted">
                <desc>Not in use. If term then show meaning from glossary in register via mouseover.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(@type='term') then let $s := id(@key, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/def/string() return concat(id(@key, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/orth/term/string(), ': ', $s) else ()"/>
                <param name="placement" value="'bottom'"/>
                <param name="fallback-placement" value="'top'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
        </elementSpec>
        <elementSpec ident="gap" mode="change">
            <model predicate="@extent" behaviour="inline">
                <desc>If predicate @extent, then show it and its extend in output text.</desc>
                <param name="content" value="@extent"/>
                <outputRendition xml:space="preserve" scope="before">
                content: ' [..';
                </outputRendition>
                <outputRendition xml:space="preserve" scope="after">
                content: '..] ';
                </outputRendition>
                <outputRendition xml:space="preserve">
                color: grey;
                </outputRendition>
            </model>
            <model behaviour="inline">
                <desc>If gap, show [ ] in text and show reason via mouseover.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="'[ ]'"/>
                <param name="alternate" value="concat('Textverlust durch ', @reason)"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model behaviour="inline">
                <desc>Default.</desc>
                <outputRendition xml:space="preserve" scope="before">
                content: '[...]';
                </outputRendition>
            </model>
        </elementSpec>
        <elementSpec ident="p" mode="change">
            <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="paragraph" cssClass="margin-left margin-right">
            <desc>If there are marginalia right and left, set margin to main text.</desc>
        </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="paragraph" cssClass="margin-right">
            <desc>If there are marginalia on the right, set margin to main text.</desc>
        </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="paragraph" cssClass="margin-left">
            <desc>If there are marginalia on the left, set margin to main text.</desc>
        </model>
                    <model predicate="following-sibling::closer and not(./following-sibling::p/following-sibling::closer)" behaviour="inline" useSourceRendition="true">
            <desc>Edition view only: Output text inline if there is not a following paragraph with a closer following (no gap between two paragraphs if there is no closer following immediately).</desc>
        </model>
                    <model predicate="@style='curly-bracket'" behaviour="paragraph" cssClass="curly-bracket"/>
                    <model behaviour="paragraph" useSourceRendition="true">
            <desc>Default: Output as paragraph.</desc>
            <outputRendition xml:space="preserve">
            text-align: justify;
            </outputRendition>
        </model>
                </elementSpec>
        <elementSpec ident="w" mode="change">
            <model predicate="$parameters?mode='normalized'" behaviour="inline">
                <desc>Edition normalized view: if words with hyphen are wrapped with w-tag, do not show gap when omitting hypen in span @type='hyphen'.</desc>
                <param name="content" value="(node() except (lb, span[@type='hyphen']))/normalize-space()[.] =&gt; string-join()"/>
            </model>
            <model behaviour="inline">
                <desc>Default.</desc>
            </model>
            <model predicate="$parameters?mode='normalized'" behaviour="inline">
                <param name="content" value="(node() except (lb, span[@type='hyphen'], supplied))/normalize-space()[.] =&gt; string-join()"/>
            </model>
        </elementSpec>
        <elementSpec ident="lb" mode="change">
<!--                    <model predicate="@n='N001' and (ancestor::ab[@rend='textblock'][1] or ancestor::div[@rend='tb cbr-li'][1] or ancestor::div[@rend='tb cbr-lo'][1] or ancestor::div[@rend='tb cbr-ri'][1] or ancestor::div[@rend='tb cbr-ro'][1] or ancestor::div[@rend='tb cbr-ti'][1] or ancestor::div[@rend='tb cbr-to'][1] or ancestor::div[@rend='tb cbr-bi'][1] or ancestor::div[@rend='tb cbr-bo'][1])" behaviour="omit">-->
<!--            <desc>If curly-bracket and first row, omit.</desc>-->
<!--        </model>-->
<!--                    <model predicate="parent::div[@rend='container'][1] and not(@n='N001')" behaviour="omit">-->
<!--            <desc>If curly-bracket and not first row, break.</desc>-->
<!--        </model>-->
                    <model predicate="parent::add[contains(@xml:id, 'ta')]" behaviour="omit">
            <desc>Omit, if parent add Tag, so that the rows with add tags are not shown, even if empty.</desc>
        </model>
                    <model predicate="following-sibling::*[1][self::add[contains(@xml:id, 'ta')]]" behaviour="omit">
            <desc>Omit, if add Tag, so that the rows with add tags are not shown, even if empty.</desc>
        </model>
                    <model predicate="$parameters?mode='normalized' and not(ancestor::closer) and not(ancestor::opener) and not(ancestor::address) and not(following-sibling::seg[@type='keepLB'][1]) and not(ancestor::head) and not(ancestor::signed)" behaviour="omit">
            <desc>Edition normalized view: Omit in normalized view, if no closer, opener, address or intentional line breaks or head or signature.</desc>
        </model>
                    <modelSequence>
            <model behaviour="break">
                <desc>Break line if diplomatic view.</desc>
                <param name="type" value="'line'"/>
                <param name="label" value="@n"/>
            </model>
            <model predicate="starts-with(@facs, 'iiif:')" behaviour="facs-lb" cssClass="facs">
                <desc>Edition diplomatic view only: Get customized behaviour, so that rows are highlighted when hovering, showing rows on facsimile.</desc>
            </model>
        </modelSequence>
                </elementSpec>
                <elementSpec ident="supplied" mode="change">
                    <model predicate="parent::choice" behaviour="inline">
            <desc>Default.</desc>
        </model>
                </elementSpec>
        <elementSpec ident="add" mode="change">
            <model predicate="contains(@xml:id, 'ta')" behaviour="omit">
                <desc>If the add tag refers to an anchor, omit.</desc>
            </model>
            <model predicate="@type='correction' and preceding::del[1]" behaviour="omit"/>
            <model predicate="not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta')) and descendant::lb" behaviour="inline" cssClass="grey">
                <desc>Line break in content: If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Direct addition of involved scribe.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(starts-with(@hand, 'fpb-') and not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef)) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'involved', 'Unbekannter Schreiber ')) else 'Ergänzung'"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta')) and not(descendant::lb)" behaviour="inline" cssClass="grey">
                <desc>No line break in content: Direct addition of involved scribe.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(starts-with(@hand, 'fpb-') and not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef)) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'involved', 'Unbekannter Schreiber ')) else 'Ergänzung'"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta')) and descendant::lb" behaviour="inline" cssClass="underlineDotted">
                <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Direct addition of main scribe.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(starts-with(@hand, 'fpb-') and @hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'main', 'Unbekannter Hauptschreiber ')) else 'Ergänzung'"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model predicate="(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta')) and not(descendant::lb)" behaviour="inline" cssClass="underlineDotted">
                <desc>No line break in content. Direct addition of main scribe.</desc>
                <param name="name" value="'pb-popover'"/>
                <param name="content" value="."/>
                <param name="alternate" value="if(starts-with(@hand, 'fpb-') and @hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/tei-publisher/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'main', 'Unbekannter Hauptschreiber ')) else 'Ergänzung'"/>
                <param name="placement" value="'top'"/>
                <param name="fallback-placement" value="'bottom'"/>
                <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
            </model>
            <model behaviour="inline">
                <desc>Default.</desc>
            </model>
        </elementSpec>
        <elementSpec ident="salute" mode="change">
            <model predicate="parent::closer" behaviour="inline"/>
            <model behaviour="block"/>
        </elementSpec>
        <elementSpec ident="ref" mode="change">
            <model predicate="@target and descendant::lb" behaviour="link" cssClass="underline">
            <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. Setting a link.</desc>
            <param name="uri" value="@target"/>
            <param name="alternate" value="@target"/>
            <param name="name" value="'pb-popover'"/>
            <param name="target" value="'_blank'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover uri="[[uri]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="@target and not(descendant::lb)" behaviour="link">
            <desc>No line break. Setting a link.</desc>
            <param name="uri" value="@target"/>
            <param name="alternate" value="@target"/>
            <param name="name" value="'pb-popover'"/>
            <param name="target" value="'_blank'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover uri="[[uri]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="not(node())" behaviour="link">
            <param name="content" value="@target"/>
            <param name="uri" value="@target"/>
        </model>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="facsimile" mode="add"/>
                <elementSpec ident="div" mode="change">
                    <model predicate="@type='title_page'" behaviour="block">
            <outputRendition xml:space="preserve">
            border: 1px solid black; padding: 5px;
            </outputRendition>
        </model>
                    <model predicate="@type='commentary'" behaviour="omit"/>
                    <model predicate="$parameters?view='notes'" behaviour="list">
            <param name="content" value="for $anchor in .//anchor/@n return  root($parameters?root)//div//note[@type='note'][@n=$anchor]"/>
            <param name="type" value="'custom'"/>
        </model>
                    <model output="web" predicate="$parameters?view='places'" behaviour="block">
            <param name="content" value="for $ref in distinct-values(.//placeName/@ref | .//rs[@type='place']/@ref) let $place := id($ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') let $lng := substring-after($geo, ' ')  return element placeName {attribute ref { $ref }, concat($name, ' (N', $lat, ', E', $lng, ')')}"/>
            <param name="longitude" value="for $ref in distinct-values(.//placeName/@ref | .//rs[@type='place']/@ref) let $place := id($ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lng := substring-after($geo, ' ')  return $lng"/>
            <param name="latitude" value="for $ref in distinct-values(.//placeName/@ref | .//rs[@type='place']/@ref) let $place := id($ref, doc('/db/apps/tei-publisher/data/register.xml')) let $geo := $place//location/geo/text() let $lat := substring-before($geo, ' ') return $lat"/>
            <param name="label" value="for $ref in distinct-values(.//placeName/@ref | .//rs[@type='place']/@ref) let $place := id($ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $place/placeName/text() return $name"/>
            <pb:template xmlns="" xml:space="preserve">
                  <pb-geolocation xmlns="http://www.tei-c.org/ns/1.0" longitude="[[longitude]]" latitude="[[latitude]]" label="[[label]]">[[content]]</pb-geolocation>
              </pb:template>
        </model>
                    <model output="web" predicate="$parameters?view='persons'" behaviour="block">
            <param name="content" value="for $ref in distinct-values(.//persName/@ref | .//rs[@type='person']/@ref) let $person := id($ref, doc('/db/apps/tei-publisher/data/register.xml')) let $name := $person/persName/text() let $birth := $person//birth/date/@when let $death := $person//death/date/@when return element persName {attribute ref { $ref }, concat($name, ' (*', $birth, ', ✝', $death, ')')}"/>
        </model>
        <model predicate="parent::body or parent::front or parent::back" behaviour="section"/>
        <model behaviour="block"/>
    </elementSpec>
    <elementSpec ident="app" mode="change">
        <model output="web" predicate="descendant::rdg[@change='#version3']" behaviour="inline" cssClass="pb-popover underlineDotted">
            <desc>Show readings in popover when version 1, 2 and 3 exist</desc>
            <param name="name" value="popover"/>
            <param name="content" value="if(normalize-space(descendant::rdg[@change='#version1']) != '') then element div {descendant::rdg[@change='#version1']/node()} else ' ... '"/>
            <param name="alt1" value="if(descendant::rdg[@change='#version1']) then for $n in descendant::rdg[@change='#version1']/node() return if ($n instance of element(lb)) then element div {()} else element div {$n} else ()"/>
            <param name="alt2" value="if(descendant::rdg[@change='#version2']) then for $n in descendant::rdg[@change='#version2']/node() return if ($n instance of element(lb)) then element div {()} else element div {$n} else ()"/>
            <param name="alt3" value="if(descendant::rdg[@change='#version3']) then for $n in descendant::rdg[@change='#version3']/node() return if ($n instance of element(lb)) then element div {()} else element div {$n} else ()"/>
            <param name="placement" value="'right'"/>
            <param name="fallback-placement" value="'left'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate"><b>Lesart 1: </b>[[alt1]]<br/><b>Lesart 2: </b>[[alt2]]<br/><b>Lesart 3: </b>[[alt3]]</span></pb-popover>
                </pb:template>
        </model>
                    <model output="web" predicate="not(descendant::rdg[@change='#version3'])" behaviour="inline" cssClass="pb-popover underlineDotted">
                    <desc>Show readings in popover when version 1 and 2, but not 3 exist</desc>
            <param name="name" value="popover"/>
            <param name="content" value="if(normalize-space(descendant::rdg[@change='#version1']) != '') then element div {descendant::rdg[@change='#version1']/node()} else ' ... '"/>
            <param name="alt1" value="if(descendant::rdg[@change='#version1']) then for $n in descendant::rdg[@change='#version1']/node() return if ($n instance of element(lb)) then element div {()} else element div {$n} else ()"/>
            <param name="alt2" value="if(descendant::rdg[@change='#version2']) then for $n in descendant::rdg[@change='#version2']/node() return if ($n instance of element(lb)) then element div {()} else element div {$n} else ()"/>
            <param name="placement" value="'right'"/>
            <param name="fallback-placement" value="'left'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate"><b>Lesart 1: </b>[[alt1]]<br/><b>Lesart 2: </b>[[alt2]]<br/></span></pb-popover>
                </pb:template>
        </model>
                    <model behaviour="alternate" cssClass="underlineDotted">
                    <desc>Show reading 1 in popover</desc>
            <param name="default" value="if(normalize-space(.//rdg[@change='#version1']) != '') then .//rdg[@change='#version1']/node() else ' ... '"/>
            <param name="alternate" value="if(.//rdg[@change='#version2'] and .//rdg[@change='#version3']) then concat('Lesart 2: ', .//rdg[@change='#version2'], '  Lesart 3: ', .//rdg[@change='#version3']) else if(.//rdg[@change='#version2']) then concat('Lesart 2: ', .//rdg[@change='#version2']) else ()"/>
        </model>
                    <model output="web" predicate="$parameters?variants = 'on'" behaviour="inline">
            <param name="content" value="node()"/>
            <pb:template xmlns="" xml:space="preserve">
      <span class="variant-highlight">[[content]]</span>
    </pb:template>
        </model>
                    <model output="web" behaviour="inline">
            <param name="content" value="node()"/>
        </model>
                </elementSpec>
                
        <elementSpec ident="item" mode="add">
                    <model output="web" predicate="$parameters?view='persons'" behaviour="listItem">
                    <desc>Show persons as listItem in container</desc>
            <param name="key" value="@key"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve">
              <li xmlns="http://www.tei-c.org/ns/1.0" class="tei-item">
                <pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">
                  [[content]]
                </pb-highlight>
              </li>
            </pb:template>
            <outputRendition xml:space="preserve">
            
              font-size: 12pt;
              pb-highlight-color: #ffff00;
            
            </outputRendition>
        </model>
                    <model output="web" predicate="$parameters?view='places'" behaviour="listItem">
                    <desc>Show places as listItem in container</desc>
            <param name="key" value="@key"/>
            <param name="highlight-self" value="'highlight-self'"/>
            <param name="duration" value="7500"/>
            <param name="content" value="."/>
            <pb:template xmlns="" xml:space="preserve">
              <li xmlns="http://www.tei-c.org/ns/1.0" class="tei-item">
                <pb-highlight key="[[key]]" highlight-self="[[highlight-self]]" duration="[[duration]]">
                  [[content]]
                </pb-highlight>
              </li>
            </pb:template>
            <outputRendition xml:space="preserve">
            
              font-size: 12pt;
              pb-highlight-color: #ffff00;
            
            </outputRendition>
        </model>
    </elementSpec>
    <elementSpec ident="w" mode="change">
                    <model predicate="$parameters?mode='normalized'" behaviour="inline">
            <desc>Edition normalized view: if words with hyphen are wrapped with w-tag, do not show gap when omitting hypen in span @type='hyphen'.</desc>
            <param name="content" value="(node() except (lb, span[@type='hyphen']))/normalize-space()[.] =&gt; string-join()"/>
        </model>
                    <model behaviour="inline">
            <desc>Default.</desc>
        </model>
                    <model predicate="$parameters?mode='normalized'" behaviour="inline">
            <param name="content" value="(node() except (lb, span[@type='hyphen'], supplied))/normalize-space()[.] =&gt; string-join()"/>
        </model>
    </elementSpec>
    <elementSpec ident="span" mode="add">
        <model predicate="not($parameters?mode='normalized') and @type='hyphen'" behaviour="inline">
        <desc>Show hyphen in diplomatic view</desc>
        </model>
        <model predicate="$parameters?mode='normalized' and @type='hyphen'" behaviour="omit">
            <desc>Omit hyphen in normalized view</desc>
        </model>
        <model predicate="child::note and child::note/lb and $parameters?mode='diplomatic'" behaviour="inline" cssClass="underlineDotted">
            <desc>Deprecated. See note with type='commented'. Show commentary in popover. </desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="note/node()"/>
            <param name="placement" value="'right'"/>
            <param name="fallback-placement" value="'left'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
        <model predicate="child::note" behaviour="inline" cssClass="underlineDotted">
            <desc>Deprecated. See note with type='commented'. Show commentary in popover. </desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="."/>
            <param name="alternate" value="note/node()"/>
            <param name="placement" value="'right'"/>
            <param name="fallback-placement" value="'left'"/>
            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
        </model>
    </elementSpec>
    <elementSpec ident="pb" mode="change">
        <model predicate="$parameters?view='places'" behaviour="omit">
            <desc>Omit in places-container</desc>
        </model>
        <model predicate="$parameters?view='persons'" behaviour="omit">
            <desc>Omit in persons-container</desc>
        </model>
        <model predicate="@type='empty'" behaviour="inline">
                <desc>If there is an empty page display Text</desc>
                <param name="content" value="concat('&lt;Leerseite ', @n,'&gt;')"/>
                <outputRendition xml:space="preserve">
                display: block; color: grey; text-align: right; font-size: 75%;
                </outputRendition>
        </model>
        <model predicate="not(@type='hidden')" behaviour="webcomponent" useSourceRendition="true">
            <desc>Display page number. If not hidden, navigate facsimile pages via page display in edition view</desc>
            <param name="content" value="@n"/>
            <param name="facs" value="let $path := id(substring-after(@facs, '#'), root($parameters?root)) return  replace($path/surface/graphic/@url, '.*/', '')"/>
            <param name="name" value="'pb-facs-link'"/>
            <param name="emit" value="'transcription'"/>
            <param name="order" value="@n"/>
            <outputRendition xml:space="preserve">
            display: block; color: grey; text-align: right; font-size: 75%;
            </outputRendition>
            <outputRendition xml:space="preserve" scope="before">
            content: ' |p.';
            </outputRendition>
            <outputRendition xml:space="preserve" scope="after">
            content: '| '
            </outputRendition>
        </model>
        <model output="latex" behaviour="inline">
            <desc>Latex page index</desc>
            <param name="content" value="'[' || @f || ':' || @n || ']'"/>
            <pb:template xmlns="" xml:space="preserve">\marginpar{[[content]]}</pb:template>
        </model>
        <model output="print" behaviour="inline">
            <desc>Print page index</desc>
            <param name="content" value="'[' || @f || ':' || @n || ']'"/>
        </model>
    </elementSpec>
    <elementSpec ident="msDesc" mode="add">
        <modelSequence>
            <model behaviour="heading">
                <desc>Metadata text 'repository'</desc>
                <param name="content" value="'Aufbewahrungsort:'"/>
                <param name="level" value="3"/>
            </model>
            <model behaviour="block">
            <desc>Metadata repository</desc>
                <param name="content" value="(//msIdentifier//repository)[1]/node()[@xml:lang='de']"/>
            </model>
            <model behaviour="heading">
            <desc>Metadata text 'inventory number'</desc>
                <param name="content" value="'Inventarnr.:'"/>
                <param name="level" value="3"/>
            </model>
            <model behaviour="block">
            <desc>Metadata inventory number</desc>
                <param name="content" value="//msIdentifier//idno[@type='id']/node()"/>
            </model>
            <model behaviour="heading">
            <desc>Metadata text 'content'</desc>
                <param name="content" value="'Inhalt:'"/>
                <param name="level" value="3"/>
            </model>
            <model behaviour="block">
            <desc>Metadata content</desc>
                <param name="content" value="//msContents//summary//desc[@xml:lang='de']/node()"/>
            </model>
        </modelSequence>
    </elementSpec>
    <elementSpec ident="publicationStmt" mode="change">
        <modelSequence>
            <model behaviour="heading">
            <desc>Metadata text 'licence'</desc>
                <param name="content" value="'Lizenz: '"/>
                <param name="level" value="3"/>
            </model>
            <model behaviour="block">
            <desc>Metadata licence</desc>
                <param name="content" value="//publisher/node()"/>
            </model>
            <model behaviour="link" cssClass="link">
            <desc>Metadata link</desc>
                <param name="link" value="//availability//licence/@target"/>
                <param name="target" value="'_blank'"/>
                <param name="content" value="//availability//licence/node()"/>
            </model>
        </modelSequence>
    </elementSpec>
    <elementSpec ident="correspDesc" mode="add"/>
    <elementSpec ident="correspAction" mode="add">
        <modelSequence>
            <model predicate="@type='sent'" behaviour="heading">
            <desc>Metadata text 'Sender'</desc>
                <param name="content" value="'Absender: '"/>
                <param name="level" value="3"/>
            </model>
            <model predicate="@type='sent'" behaviour="block">
            <desc>Metadata sender</desc>
                <param name="content" value="if((count(persName) &gt; 1) and (persName[position() != last()])) then (for $pers in persName/node() return concat($pers,',&amp;#xa;')) else persName/node()"/>
            </model>
            <model predicate="@type='received'" behaviour="heading">
             <desc>Metadata text 'Receiver'</desc>
                <param name="content" value="'Empfänger: '"/>
                <param name="level" value="3"/>
            </model>
            <model predicate="@type='received'" behaviour="block">
             <desc>Metadata receiver</desc>
                <param name="content" value="if((count(persName) &gt; 1) and (persName[position() != last()])) then (for $pers in persName/node() return concat($pers,',&amp;#xa;')) else persName/node()"/>
            </model>
            <model predicate="@type='sent'" behaviour="heading">
            <desc>Metadata text 'place of writing'</desc>
                <param name="content" value="'Abfassungsort und -datum: '"/>
                <param name="level" value="3"/>
            </model>
            <model predicate="@type='sent'" behaviour="block">
            <desc>Metadata place of writing</desc>
                <param name="content" value="concat(placeName/node(), ', ', date/node())"/>
            </model>
        </modelSequence>
    </elementSpec>
    <elementSpec ident="signed" mode="change">
        <model predicate="parent::closer" behaviour="inline">
            <desc>If signature has parent 'closer' treat it inline</desc>
        </model>
        <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
            <desc>If there are marginalia right and left, set margin to element signed.</desc>
        </model>
        <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
            <desc>If there are marginalia on the right, set margin to element signed.</desc>
        </model>
        <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
            <desc>If there are marginalia on the left, set margin to element signed.</desc>
        </model>
    </elementSpec>
    <elementSpec ident="del" mode="change">
        <model predicate="self::del[following-sibling::*[not(self::lb)][1][self::anchor][concat('t', @xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id]]" behaviour="omit">
            <desc>Omit if there is an anchor</desc>
        </model>
        <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']//lb" behaviour="inline" cssClass="grey triangle">
            <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. No anchor. Involved Scribe in del and add</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'] return if(self::del//lb[1]) then (self::del//lb[1], $add/node()) else $add/node()"/>
            <param name="alternate" value="let $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef, $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers], $del := self::del[@hand=$refPers], $hand := $add/@hand, $name := $add/id($hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName/text(), $original := normalize-space(string-join(for $n in $del/node() return typeswitch($n) case text() return $n case element(lb) return ' || ' case element(choice) return concat(string($n/abbr), ' (= ', string($n/expan), ')') default return string-join(for $c in $n/node() return if($c/self::lb) then ' || ' else if($c/self::choice) then concat(string($c/abbr), ' (= ', string($c/expan), ')') else if($c instance of text()) then $c else ()))), $unclear := if(exists(self::del//unclear[@reason='unsure'])) then '(unsicher)' else if(exists(self::del//unclear[@reason='illegible'])) then ' (unleserlich)' else '' return if($name) then concat('Korrigiert von: ', $name, '; Ursprüngliche Lesart: ', $original, $unclear) else if(contains($hand, 'involved')) then concat('Korrigiert von: ', replace($hand, 'involved', 'Unbekannter Schreiber '), '; Ursprüngliche Lesart: ', $original, $unclear) else concat('Ursprüngliche Lesart: ', $original, $unclear)"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve">
                <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]"><span slot="alternate">[[alternate]]</span>[[content]]<span slot="alternate">[[alternate]]</span></pb-popover>
            </pb:template>
        </model>
        <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers] and not(following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']//lb)" behaviour="inline" cssClass="grey triangle">
            <desc>No line break. No anchor. Involved Scribe in del and add</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'] return if(self::del//lb[1]) then (self::del//lb[1], $add/node()) else $add/node()"/>
            <param name="alternate" value="let $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef, $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers], $del := self::del[@hand=$refPers], $hand := $add/@hand, $name := $add/id($hand, doc('/db/apps/tei-publisher/data/register.xml'))/persName/text(), $original := normalize-space(string-join(for $n in $del/node() return typeswitch($n) case text() return $n case element(lb) return ' || ' case element(choice) return concat(string($n/abbr), ' (= ', string($n/expan), ')') default return string-join(for $c in $n/node() return if($c/self::lb) then ' || ' else if($c/self::choice) then concat(string($c/abbr), ' (= ', string($c/expan), ')') else if($c instance of text()) then $c else ()))), $unclear := if(exists(self::del//unclear[@reason='unsure'])) then '(unsicher)' else if(exists(self::del//unclear[@reason='illegible'])) then ' (unleserlich)' else '' return if($name) then concat('Korrigiert von: ', $name, '; Ursprüngliche Lesart: ', $original, $unclear) else if(contains($hand, 'involved')) then concat('Korrigiert von: ', replace($hand, 'involved', 'Unbekannter Schreiber '), '; Ursprüngliche Lesart: ', $original, $unclear) else concat('Ursprüngliche Lesart: ', $original, $unclear)"/>
            <param name="placement" value="'top'"/>
            <param name="fallback-placement" value="'bottom'"/>
            <pb:template xmlns="" xml:space="preserve">
                <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover>
            </pb:template>
        </model>
        <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']//lb" behaviour="inline" cssClass="triangle">
            <desc>Line break in content. If there is a line break and the lines are wrapped in pb-facs-link (text not normalized), the popover should be doubled for mouse over to appear in both lines. No anchor. Main Scribe in del and add</desc>
            <param name="name" value="'pb-popover'"/>
            <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'] return if(self::del//lb[1]) then (self::del//lb[1], $add/node()) else $add/node()"/>
