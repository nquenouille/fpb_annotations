            <!--         <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id) and preceding-sibling::del[1]/unclear[@reason='illegible']" behaviour="inline">-->
            <!--            <desc>Annotation view: add[correction] with Main Scribe and unclear[illegible] del</desc>-->
            <!--            <param name="name" value="'pb-popover'"/>-->
            <!--            <param name="content" value="id(concat('t', @xml:id), root($parameters?root))[@type='correction']/node()"/>-->
            <!--            <param name="alternate" value="if (id(concat('t', @xml:id), root($parameters?root))) then concat('Korrigiert von: ', for $a in . return if(concat('t', $a/@xml:id) = root($parameters?root)//add/@xml:id) then (if(starts-with(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand, 'fpb-')) then root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/id(@hand, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/persName/text() else if(not(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand='')) then replace(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand, 'main', 'Unbekannter Hauptschreiber ')  else()) else (), ' Ursprüngliche Lesart: ', preceding-sibling::del[1], ' (unleserlich)') else concat('Korrigiert von: ', for $a in . return if(concat('t', $a/@xml:id) = root($parameters?root)//add/@xml:id) then (if(starts-with(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand, 'fpb-')) then root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/id(@hand, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/persName/text() else if(not(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand='')) then replace(root($parameters?root)//add[@xml:id = concat('t', $a/@xml:id)]/@hand, 'main', 'Unbekannter Hauptschreiber ')  else()) else ())"/>-->
            <!--            <param name="placement" value="'top'"/>-->
            <!--            <param name="fallback-placement" value="'bottom'"/>-->
            <!--            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>-->
            <!--            <outputRendition xml:space="preserve">-->
            <!--            text-decoration: underline dotted;-->
            <!--            </outputRendition>-->
            <!--        </model>-->
                                    
                        <!-- add[correction] with Involved Scribe -->
                        <model predicate="contains(@xml:id, 'a') and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id) and not((concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')][@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef]/@xml:id))" behaviour="inline" cssClass="underlineDotted">
                            <desc>Annotation view: add[correction] with Involved Scribe</desc>
                            <param name="name" value="'pb-popover'"/>
                            <param name="content" value="preceding::del[1]/node()"/>
                            <param name="alternate" value="let $main := id(concat('t', @xml:id), root($parameters?root)) return                                              string-join(                                               for $a in ($main, $main/child::add)                                               let $hand :=                                                  if($a/@hand) then                                                   if(starts-with($a/@hand, 'fpb-')) then                                                     string($a/id(@hand, doc('/db/apps/annotations/data/register.xml'))/persName)                                                   else                                                     replace($a/@hand, 'involved', 'Unbekannter Schreiber ')                                                 else 'Unbekannter Schreiber'                                               let $delText := string-join($a/node()[not(self::add)], '')                                               let $del := $a/preceding::del[1]                                               let $new := string-join($a/node()[not(self::add)], '')                                               let $status := if($del/unclear[@reason='unsure']) then ' (unsicher)' else if ($del/unclear[@reason='illegible']) then ' (unleserlich)' else ''                                               return concat('Korrigiert von: ', $hand, ' zu: ', $new, $status)                                             , '; ')"/>
                            <param name="placement" value="'top'"/>
                            <param name="fallback-placement" value="'bottom'"/>
                            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                        </model>
                    
                        <!-- add[correction] with Main Scribe -->
                        <model predicate="contains(@xml:id,'a') and concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id and (concat('t', ./@xml:id) = root($parameters?root)//add[@type='correction' and ((@hand) and (starts-with(@hand,'main') or starts-with(@hand,'fpb-')))]/@xml:id)" behaviour="inline" cssClass="underlineDotted">
                            <desc>Annotation / Edition normalized view: add[correction] with Main Scribe</desc>
                            <param name="name" value="'pb-popover'"/>
                            <param name="content" value="let $add := id(concat('t', @xml:id), root($parameters?root))                                            return                                              if ($add//add[@type='correction'])                                              then $add//add[@type='correction'][last()]/node()                                              else $add/node()"/>
                            <param name="alternate" value="let $root := root($parameters?root) let $add := id(concat('t', @xml:id), $root) let $chain :=     if ($add//add[@type='correction']) then ($add, $add//add[@type='correction'])     else ($add)  return string-join(     for $i in 1 to count($chain)     let $a := $chain[$i]     let $hand :=         if ($a/@hand) then             if (starts-with($a/@hand,'fpb-')) then                 string($a/id(@hand, doc('/db/apps/annotations/data/register.xml'))/persName)             else replace($a/@hand,'main','Unbekannter Hauptschreiber ')         else 'Unbekannter Hauptschreiber'     let $del := $a/preceding::del[1]     let $delText := string-join($del//text()[not(parent::expan)],'')     let $altText := string-join($del//expan//text(),'')     let $status :=         if ($del/unclear[@reason='unsure']) then ' (unsicher)'         else if ($del/unclear[@reason='illegible']) then ' (unleserlich)'         else ''     return         if (count($chain)=1) then             normalize-space(concat(                 'Korrigiert von: ', $hand, '; ',                 'Ursprüngliche Lesart: ', $delText,                 if ($altText) then concat(' (= ', $altText, ')') else (),                 $status             ))         else             normalize-space(concat(                 'Korrigiert von: ', $hand, '; ',                 'Ursprüngliche Lesart ', $i, ': ', $delText,                 if ($altText) then concat(' (= ', $altText, ')') else (),                 $status)             ) , '; ')"/>
                            <param name="placement" value="'top'"/>
                            <param name="fallback-placement" value="'bottom'"/>
                            <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                        </model>                        
                    </modelSequence>
                </elementSpec>
                <elementSpec ident="term" mode="add">
                    <model predicate="@type='term'" behaviour="inline" cssClass="underlineDotted">
                        <desc>Not in use. If term then show meaning from glossary in register via mouseover.</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="if(@type='term') then let $s := id(@key, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/def/string() return  concat(id(@key, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/orth/term/string(), ': ', $s) else ()"/>
                        <param name="placement" value="'bottom'"/>
                        <param name="fallback-placement" value="'top'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                </elementSpec>
                <elementSpec ident="gap" mode="change">
                    <model behaviour="inline">
                        <desc>If gap, show [ ] in text and show reason via mouseover.</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="'[ ]'"/>
                        <param name="alternate" value="concat('Textverlust durch ', @reason)"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model behaviour="inline">
                        <desc>Default.</desc>
                        <outputRendition xml:space="preserve" scope="before">
                            content: '[...]';
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="p" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="paragraph" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left, set margin to main text.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="paragraph" cssClass="margin-right">
                        <desc>If there are marginalia on the right, set margin to main text.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="paragraph" cssClass="margin-left">
                    <desc>If there are marginalia on the left, set margin to main text.</desc>
                    </model>
                    <model behaviour="paragraph" predicate="@style='curly-bracket'" cssClass="curly-bracket"/>
                    <model behaviour="paragraph" useSourceRendition="true">
                        <desc>Default: output as paragraph.</desc>
                        <outputRendition xml:space="preserve">
                            text-align: justify;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="lb" mode="change">
        <!--        <model predicate="@n='N001' and (ancestor::div[@rend='textblock'][1] or ancestor::div[@rend='tb cbr-li'][1] or ancestor::div[@rend='tb cbr-lo'][1] or ancestor::div[@rend='tb cbr-ri'][1] or ancestor::div[@rend='tb cbr-ro'][1] or ancestor::div[@rend='tb cbr-ti'][1] or ancestor::div[@rend='tb cbr-to'][1] or ancestor::div[@rend='tb cbr-bi'][1] or ancestor::div[@rend='tb cbr-bo'][1])" behaviour="omit">-->
        <!--             <desc>If curly-bracket and first row, omit.</desc>-->
        <!--        </model>-->
        <!--        <model predicate="parent::div[@rend='container'][1] and not(@n='N001')" behaviour="break">-->
        <!--             <desc>If curly-bracket and not first row, break.</desc>-->
        <!--        </model>-->
                    <model predicate="following-sibling::*[1][self::add[contains(@xml:id, 'ta')]]" behaviour="omit">
                        <desc>Omit, if add Tag, so that the rows with add tags are not shown, even if empty.</desc>
                    </model>
                    <model predicate="$parameters?mode='normalized' and not(ancestor::closer) and not(ancestor::opener) and not(ancestor::address) and not(following-sibling::orig[@type='keepLB'][1]) and not(ancestor::head) and not(ancestor::signed)" behaviour="omit">
                        <desc>Edition normalized view: Omit in normalized view, if no closer, opender, address or intentional line breaks or head or signature.</desc>
                    </model>
                    <model behaviour="break">
                        <desc>Break line if diplomatic view.</desc>
                        <param name="type" value="'line'"/>
                        <param name="label" value="@n"/>
                    </model>
                </elementSpec>
                <elementSpec ident="supplied" mode="change">
                    <model predicate="parent::choice" behaviour="inline">
                        <desc>Default.</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="add" mode="change">
                    <model predicate="contains(@xml:id, 'ta')" behaviour="omit">
                        <desc>If the add tag refers to an anchor, omit.</desc>
                    </model>
                    <model predicate="@type='correction' and preceding::del[1]" behaviour="omit"/>
                        
                    <!-- Involved Scribe -->
                    <model predicate="not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta'))" behaviour="inline" cssClass="grey">
                        <desc>Addition by involved scribe</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="if(starts-with(@hand, 'fpb-') and not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef)) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'involved', 'Unbekannter Schreiber ')) else 'Ergänzung'"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                
                    <!-- Main Scribe -->
                    <model predicate="(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) and @type='addition' and not(contains(@xml:id, 'ta'))" behaviour="inline" cssClass="underlineDotted">
                        <desc>Addition by main scribe</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="if(starts-with(@hand, 'fpb-') and @hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef) then concat('Ergänzt von: ', id(@hand, doc(&#34;/db/apps/annotations/data/register.xml&#34;))/persName/text()) else if(not(@hand='')) then concat('Ergänzt von: ', replace(@hand, 'main', 'Unbekannter Hauptschreiber ')) else 'Ergänzung'"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model predicate="@type='addition' and not(contains(@xml:id, 'ta'))" behaviour="inline" cssClass="underlineDotted">
                        <desc>Addition</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="concat('Ergänzt von: ', @hand)"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="salute" mode="change">
                    <model predicate="parent::closer" behaviour="inline"/>
                    <model behaviour="block"/>
                </elementSpec>
                <elementSpec ident="ref" mode="change">
                    <model predicate="@target" behaviour="link" cssClass="underline">
                        <param name="uri" value="@target"/>
                        <param name="alternate" value="@target"/>
                        <param name="name" value="'pb-popover'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover uri="[[uri]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model predicate="not(node())" behaviour="link">
                        <param name="content" value="@target"/>
                        <param name="uri" value="@target"/>
                    </model>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="front" mode="change">
                    <model behaviour="block"/>
                </elementSpec>
                <elementSpec ident="back" mode="change">
                    <model behaviour="block"/>
                </elementSpec>
                <elementSpec ident="div" mode="change">
                    <model predicate="@type='commentary' or @type='commentary_front' or @type='commentary_back'" behaviour="omit"/>
                    <model predicate="@type='title_page'" behaviour="block">
                        <outputRendition xml:space="preserve">
                            border: 1px solid black; padding: 5px;
                        </outputRendition>
                    </model>
                    <model predicate="$parameters?view='notes'" behaviour="list">
                    <model predicate="$parameters?mode='omitCommentary' and (@type='commentary' or @type='commentary_front' or @type='commentary_back')" behaviour="omit"/>
                    <model predicate="parent::body or parent::front or parent::back" behaviour="section"/>
                        <param name="content" value="for $anchor in .//anchor/@n return  root($parameters?root)//div[@type='commentary']//note[@n=$anchor]"/>
                        <param name="type" value="'custom'"/>
                    </model>
                    <model predicate="parent::body or parent::front or parent::back" behaviour="section"/>
                    <model behaviour="block"/>
                </elementSpec>
                <elementSpec ident="span" mode="add">
                    <model predicate="not($parameters?mode='normalized') and @type='hyphen'" behaviour="inline">
                        <desc>Show hyphen in diplomatic view</desc>
                    </model>
                    <!-- <model predicate="$parameters?mode='normalized' and @type='hyphen'" behaviour="omit"/> -->
                    <model predicate="child::note" behaviour="inline" cssClass="underline">
                        <desc>Deprecated. See note with type='commentary'. Show commentary in popover. </desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="note/node()"/>
                        <param name="placement" value="'right'"/>
                        <param name="fallback-placement" value="'left'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                </elementSpec>
                <elementSpec ident="pb" mode="change">
                    <model predicate="@type='empty'" behaviour="inline">
                        <desc>If there is an empty page display Text</desc>
                        <param name="content" value="concat('&lt;Leerseite ', @n,'&gt;')"/>
                        <outputRendition xml:space="preserve">
                            display: block; color: grey; text-align: right; font-size: 75%;
                        </outputRendition>
                    </model>
                    <model predicate="not(@type='hidden')" behaviour="webcomponent" useSourceRendition="true">
                        <desc>Display page number. If not hidden, navigate facsimile pages via page display in edition view</desc>
                        <param name="content" value="@n"/>
                        <param name="facs" value="let $path := id(substring-after(@facs, '#'), root($parameters?root)) return  $path/surface/graphic/@url"/>
                        <param name="name" value="'pb-facs-link'"/>
                        <param name="emit" value="'transcription'"/>
                        <param name="order" value="@n"/>
                        <outputRendition xml:space="preserve">
                            display: block; color: grey; text-align: right; font-size: 75%; padding-right: 20px;
                        </outputRendition>
                        <outputRendition xml:space="preserve" scope="before">
                            content: ' |p.';
                        </outputRendition>
                        <outputRendition xml:space="preserve" scope="after">
                            content: '| '
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="msDesc" mode="add">
                    <modelSequence>
                        <model behaviour="heading">
                            <desc>Metadata text 'repository'</desc>
                            <param name="content" value="'Aufbewahrungsort:'"/>
                            <param name="level" value="3"/>
                        </model>
                        <model behaviour="block">
                        <desc>Metadata repository</desc>
                            <param name="content" value="(//msIdentifier//repository)[1]/node()"/>
                        </model>
                        <model behaviour="heading">
                            <desc>Metadata text 'inventory number'</desc>
                            <param name="content" value="'Inventarnr.:'"/>
                            <param name="level" value="3"/>
                        </model>
                        <model behaviour="block">
                            <desc>Metadata inventory number</desc>
                            <param name="content" value="//msIdentifier//idno[@type='id']/node()"/>
                        </model>
                        <model behaviour="heading">
                            <desc>Metadata text 'content'</desc>
                            <param name="content" value="'Inhalt:'"/>
                            <param name="level" value="3"/>
                        </model>
                        <model behaviour="block">
                            <desc>Metadata content</desc>
                            <param name="content" value="//msContents//summary//desc/node()"/>
                        </model>
                    </modelSequence>
                </elementSpec>
                <elementSpec ident="publicationStmt" mode="change">
                    <modelSequence>
                        <model behaviour="heading">
                            <desc>Metadata text 'licence'</desc>
                            <param name="content" value="'Lizenz: '"/>
                            <param name="level" value="3"/>
                        </model>
                        <model behaviour="block">
                            <desc>Metadata licence</desc>
                            <param name="content" value="//publisher/node()"/>
                        </model>
                        <model behaviour="link" cssClass="link">
                            <desc>Metadata link</desc>
                            <param name="link" value="//availability//licence/@target"/>
                            <param name="target" value="'_blank'"/>
                            <param name="content" value="//availability//licence/node()"/>
                        </model>
                    </modelSequence>
                </elementSpec>
                <elementSpec ident="correspDesc" mode="add"/>
                <elementSpec ident="correspAction" mode="add">
                    <modelSequence>
                        <model predicate="@type='sent'" behaviour="heading">
                            <desc>Metadata text 'Sender'</desc>
                            <param name="content" value="'Absender: '"/>
                            <param name="level" value="3"/>
                        </model>
                        <model predicate="@type='sent'" behaviour="block">
                            <desc>Metadata sender</desc>
                            <param name="content" value="if((count(persName) &gt; 1) and (persName[position() != last()])) then (for $pers in persName/node() return concat($pers,',&amp;#xa;')) else persName/node()"/>
                        </model>
                        <model predicate="@type='received'" behaviour="heading">
                            <desc>Metadata text 'Receiver'</desc>
                            <param name="content" value="'Empfänger: '"/>
                            <param name="level" value="3"/>
                        </model>
                        <model predicate="@type='received'" behaviour="block">
                            <desc>Metadata receiver</desc>
                            <param name="content" value="if((count(persName) &gt; 1) and (persName[position() != last()])) then (for $pers in persName/node() return concat($pers,',&amp;#xa;')) else persName/node()"/>
                        </model>
                        <model predicate="@type='sent'" behaviour="heading">
                            <desc>Metadata text 'place of writing'</desc>
                            <param name="content" value="'Abfassungsort und -datum: '"/>
                            <param name="level" value="3"/>
                        </model>
                        <model predicate="@type='sent'" behaviour="block">
                            <desc>Metadata place of writing</desc>
                            <param name="content" value="concat(placeName/node(), ', ', date/node())"/>
                        </model>
                    </modelSequence>
                </elementSpec>
                <elementSpec ident="signed" mode="change">
                    <model predicate="parent::closer" behaviour="inline">
                        <desc>If signature has parent 'closer' treat it inline</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left, set margin to element signed.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right, set margin to element signed.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left, set margin to element signed.</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="del" mode="change">
                    <!-- omit if there is an anchor -->
                    <model predicate="self::del[following-sibling::*[not(self::lb)][1][self::anchor][concat('t', @xml:id) = root($parameters?root)//add[@type='correction' and not(@place='inspace')]/@xml:id]]" behaviour="omit">
                        <desc>Omit if there is an anchor</desc>
                    </model>
                    <!-- Involved Scribe in del and add -->
                    <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef                              return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers]" behaviour="inline" cssClass="grey">
                        <desc>Involved Scribe in del and add</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']                                         return                                             if(self::del//lb[1])                                             then (self::del//lb[1], $add/node())                                             else $add/node()"/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef,                                 $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers],                                 $del := self::del[@hand=$refPers],                                 $hand := $add/@hand,                                 $name := $add/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $original := normalize-space(                                             string-join(                                                 for $n in $del/node()                                                 return                                                     typeswitch($n)                                                                                                  case text()                                                             return $n                                                                                                  case element(lb)                                                             return ' || '                                                                                                  case element(choice)                                                             return concat(                                                                 string($n/abbr),                                                                 ' (= ',                                                                 string($n/expan),                                                                 ')'                                                             )                                                                                                  default                                                             return string-join(                                                                 for $c in $n/node()                                                                 return                                                                     if($c/self::lb)                                                                     then ' || '                                                                     else if($c/self::choice)                                                                     then concat(string($c/abbr), ' [= ', string($c/expan), ']')                                                                     else if($c instance of text())                                                                     then $c                                                                     else ()                                                             )                                             )                                         ),                                 $unclear := if(exists(self::del//unclear[@reason='unsure'])) then ' (unsicher)' else if(exists(self::del//unclear[@reason='illegible'])) then ' (unleserlich)' else ''                             return                                  if($name) then concat('Korrigiert von: ', $name, '; Ursprüngliche Lesart: ', $original, $unclear)                                 else if(contains($hand, 'involved')) then                                     concat('Korrigiert von: ', replace($hand, 'involved', 'Unbekannter Schreiber '), '; Ursprüngliche Lesart: ', $original, $unclear)                                 else                                     concat('Ursprüngliche Lesart: ', $original, $unclear)             "/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                        <outputRendition>
                            text-emphasis-style: triangle;
                            text-emphasis-position: under;
                            text-emphasis-color: blue;
                            white-space: nowrap;
                        </outputRendition>
                    </model>
                    <!-- Main Scribe in del and add -->
                    <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef                              return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers]" behaviour="inline" >
                        <desc>Main Scribe in del and add</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']                                         return                                             if(self::del//lb[1])                                             then (self::del//lb[1], $add/node())                                             else $add/node()"/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef,                                 $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers],                                 $del := self::del[@hand=$refPers],                                 $hand := $add/@hand,                                 $name := $add/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $original := normalize-space(                                             string-join(                                                 for $n in $del/node()                                                 return                                                     typeswitch($n)                                                                                                  case text()                                                             return $n                                                                                                  case element(lb)                                                             return ' || '                                                                                                  case element(choice)                                                             return concat(                                                                 string($n/abbr),                                                                 ' [= ',                                                                 string($n/expan),                                                                 ']'                                                             )                                                                                                  default                                                             return string-join(                                                                 for $c in $n/node()                                                                 return                                                                     if($c/self::lb)                                                                     then ' || '                                                                     else if($c/self::choice)                                                                     then concat(string($c/abbr), ' [= ', string($c/expan), ']')                                                                     else if($c instance of text())                                                                     then $c                                                                     else ()                                                             )                                             )                                         ),                                 $unclear := if(exists(self::del//unclear[@reason='unsure'])) then ' (unsicher)' else if(exists(self::del//unclear[@reason='illegible'])) then ' (unleserlich)' else ''                             return                                  if($name) then concat('Korrigiert von: ', $name, '; Ursprüngliche Lesart: ', $original, $unclear)                                 else if(contains($hand, 'main')) then                                     concat('Korrigiert von: ', replace($hand, 'main', 'Unbekannter Hauptschreiber '), '; Ursprüngliche Lesart: ', $original, $unclear)                                 else                                     concat('Ursprüngliche Lesart: ', $original, $unclear)             "/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                        <outputRendition>
                            text-emphasis-style: triangle;
                            text-emphasis-position: under;
                            text-emphasis-color: blue;
                            white-space: nowrap;
                        </outputRendition>
                    </model>
                
                    <!-- Involved Scribe in del and main scribe in add -->
                    <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef                              return self::del[not(@hand = $refPers)] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers]" behaviour="inline">
                        <desc>Involved Scribe in del and main scribe in add</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="let $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace']                                         return                                             if(self::del//lb[1])                                             then (self::del//lb[1], $add/node())                                             else $add/node()"/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef,                                 $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers],                                 $del := self::del[not(@hand=$refPers)],                                 $hand := $add/@hand,                                 $name := $add/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $nameDel := if(contains(@hand, 'involved')) then replace(@hand, 'involved', 'Unbekannter Schreiber ') else self::del/id(@hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $original := normalize-space(                                             string-join(                                                 for $n in $del/node()                                                 return                                                     typeswitch($n)                                                                                                  case text()                                                             return $n                                                                                                  case element(lb)                                                             return ' || '                                                                                                  case element(choice)                                                             return concat(                                                                 string($n/abbr),                                                                 ' [= ',                                                                 string($n/expan),                                                                 ']'                                                             )                                                                                                  default                                                             return string-join(                                                                 for $c in $n/node()                                                                 return                                                                     if($c/self::lb)                                                                     then ' || '                                                                     else if($c/self::choice)                                                                     then concat(string($c/abbr), ' [= ', string($c/expan), ']')                                                                     else if($c instance of text())                                                                     then $c                                                                     else ()                                                             )                                             )                                         ),                                 $unclear := if(exists(self::del//unclear[@reason='unsure'])) then ' (unsicher)' else if(exists(self::del//unclear[@reason='illegible'])) then ' (unleserlich)' else ''                             return                                  if($name) then concat('Korrigiert von: ', $name, '; Ursprüngliche Lesart (gestrichen von: ', $nameDel, '): ', $original, $unclear)                                 else if(contains($hand, 'main')) then                                     concat('Korrigiert von: ', replace($hand, 'main', 'Unbekannter Hauptschreiber '), '; Ursprüngliche Lesart (gestrichen von: ', $nameDel, '): ', $original, $unclear)                                 else                                     concat('Ursprüngliche Lesart (gestrichen von: ', $nameDel, '): ',  $original, $unclear)             "/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                        <outputRendition>
                            text-emphasis-style: triangle;
                            text-emphasis-position: under;
                            text-emphasis-color: blue;
                            white-space: nowrap;
                        </outputRendition>
                    </model>
                
                
                    <!-- Main Scribe in del and involved scribe in add -->
                    <model predicate="let $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef                              return self::del[@hand = $refPers] and following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][not(@hand = $refPers)]" behaviour="inline" cssClass="underlineDotted">
                        <desc>Main Scribe in del and involved scribe in add</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="if(self::del[unclear[@reason='illegible'] and not(text()[normalize-space()])]) then '〈…〉' else self::del/node()"/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef,                                 $add := following-sibling::*[not(self::lb)][1][self::add][@type='correction'][@place='inspace'][@hand = $refPers],                                 $hand := $add/@hand,                                 $name := $add/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $correction := normalize-space(                                             string-join(                                                 for $n in $add/node()                                                 return                                                     typeswitch($n)                                                                                                  case text()                                                             return $n                                                                                                  case element(lb)                                                             return ' || '                                                                                                  case element(choice)                                                             return concat(                                                                 string($n/abbr),                                                                 ' [= ',                                                                 string($n/expan),                                                                 ']'                                                             )                                                                                                  default                                                             return string-join(                                                                 for $c in $n/node()                                                                 return                                                                     if($c/self::lb)                                                                     then ' || '                                                                     else if($c/self::choice)                                                                     then concat(string($c/abbr), ' [= ', string($c/expan), ']')                                                                     else if($c instance of text())                                                                     then $c                                                                     else ()                                                             )                                             )                                         ),                                 $unclear := if(exists($add//unclear[@reason='unsure'])) then ' (unsicher)' else if(exists($add//unclear[@reason='illegible'])) then ' (unleserlich)' else ''                             return                                  if($name) then concat('Korrigiert von: ', $name, 'zu: ', $correction, $unclear)                                 else if(contains($hand, 'involved')) then                                     concat('Korrigiert von: ', replace($hand, 'involved', 'Unbekannter Schreiber '), ' zu: ', $correction, $unclear)                                 else                                     concat('Korrigiert zu: ', $correction, $unclear)             "/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                    </model>
                
            
                
                    <!-- parent add with anchor -> omit -->
                    <model predicate="parent::add[1] and parent::add[1]/following::anchor[1]" behaviour="omit">
                        <desc>parent add with anchor -> omit</desc>
                    </model>

                    <!-- del of Main Scribe without correction -->
                    <model predicate="not(following-sibling::*[not(self::lb)][1][self::add and @type='correction']) and @hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef" behaviour="inline" cssClass="underlineDotted">
                        <desc>del of Main Scribe without correction</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="                     '〈…〉'             "/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='main']/@scribeRef,                                 $del := self::del[@hand=$refPers],                                 $hand := $del/@hand,                                 $name := $del/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text(),                                 $original := normalize-space(                                             string-join(                                                 for $n in $del/node()                                                 return                                                     typeswitch($n)                                                                                                  case text()                                                             return $n                                                                                                  case element(lb)                                                             return ' || '                                                                                                  case element(choice)                                                             return concat(                                                                 string($n/abbr),                                                                 ' [= ',                                                                 string($n/expan),                                                                 ']'                                                             )                                                                                                  default                                                             return string-join(                                                                 for $c in $n/node()                                                                 return                                                                     if($c/self::lb)                                                                     then ' || '                                                                     else if($c/self::choice)                                                                     then concat(string($c/abbr), ' [= ', string($c/expan), ']')                                                                     else if($c instance of text())                                                                     then $c                                                                     else ()                                                             )                                             )                                         ),                                 $unclear := if(exists($del//unclear[@reason='unsure'])) then ' (unsicher)' else if(exists($del//unclear[@reason='illegible'])) then ' (unleserlich)' else ''                             return                                  if($name) then concat('Gestrichen von: ', $name, '; Ursprüngliche Lesart: ', $original, $unclear)                                 else if(contains($hand, 'main')) then                                     concat('Gestrichen von: ', replace($hand, 'main', 'Unbekannter Hauptschreiber '), '; Ursprüngliche Lesart: ', $original, $unclear)                                 else                                     concat('Gestrichen von: ', $original, $unclear)"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                    </model>

                    <!-- del of Involved Scribe without correction -->
                    <model predicate="not(following-sibling::*[not(self::lb)][1][self::add and @type='correction']) and not(@hand = root($parameters?root)//scriptNote[@scribe='main']/@scribeRef)" behaviour="inline" cssClass="underlineDotted">
                        <desc>del of Involved Scribe without correction</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="let                                 $refPers := root($parameters?root)//scriptNote[@scribe='involved']/@scribeRef,                                 $del := self::del[@hand=$refPers],                                 $hand := $del/@hand,                                 $name := $del/id($hand, doc('/db/apps/annotations/data/register.xml'))/persName/text()                             return                                  if($name) then concat('Gestrichen von: ', $name)                                 else if(contains($hand, 'involved')) then                                     concat('Gestrichen von: ', replace($hand, 'involved', 'Unbekannter Schreiber '))                                 else                                     'Gestrichen von: Unbekannter Schreiber'"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve">
                            <pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">
                                [[content]]
                                <span slot="alternate">[[alternate]]</span>
                            </pb-popover>
                        </pb:template>
                    </model>
                    <model predicate="following::*[1][self::anchor[position() = 1]]" behaviour="omit">
                        <desc>Omit if anchor immediately after del</desc>
                    </model>

        <!--        <model behaviour="inline">-->
        <!--            <desc>Default</desc>-->
        <!--            <outputRendition xml:space="preserve">-->
        <!--                text-decoration: line-through;-->
        <!--            </outputRendition>-->
        <!--        </model>-->
                </elementSpec>
                <elementSpec ident="birth" mode="add">
                    <model predicate="@when" behaviour="inline">
                        <desc>Register: Show birth dates</desc>
                        <param name="content" value="if(following-sibling::death[1])then concat('(*', substring(@when, 0, 5), ', ') else concat('(*', substring(@when, 0, 5), ')')"/>
                        <outputRendition xml:space="preserve">
                            font-size: 80%;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="occupation" mode="add">
                    <model predicate="parent::person" behaviour="omit">
                        <desc>Omit occupation in register</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="death" mode="add">
                    <model predicate="@when" behaviour="inline">
                        <desc>Register: Show death dates</desc>
                        <param name="content" value="if(preceding-sibling::birth[1])then concat('✝', substring(@when, 0, 5), ')') else concat('(✝', substring(@when, 0, 5), ')')"/>
                        <outputRendition xml:space="preserve">
                            font-size: 80%;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="closer" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after closer, set margin to element closer.</desc>
                    </model>
                    <model predicate="preceding::note[@place='margin-right'] and preceding::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right">
                    <desc>If there are marginalia on the right before closer, set margin to element closer.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after closer, set margin to element closer.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after closer, set margin to element closer.</desc>
                    </model>
                    <model predicate="preceding::note[@place='margin-left']" behaviour="block" cssClass="margin-left">
                    <desc>If there are marginalia on the left before closer, set margin to element closer.</desc>
                    </model>
                    <model predicate="preceding::note[@place='margin-right']" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right before closer, set margin to element closer.</desc>
                    </model>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="opener" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after opener, set margin to element opener.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after opener, set margin to element opener.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after opener, set margin to element opener.</desc>
                    </model>
                    <model behaviour="inline">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="address" mode="add">
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-right'] and following::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after address, set margin to element address.</desc>
                    </model>
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after address, set margin to element address.</desc>
                    </model>
                    <model predicate="not(ancestor::closer) and following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after address, set margin to element address.</desc>
                    </model>
                    <model behaviour="inline">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="unclear" mode="change">
                    <model predicate="not(@reason='illegible')" behaviour="inline" cssClass="underlineDotted">
                        <desc>If text unclear and not illegible and note @type='commentary set content or if nothing set〈…〉and put popover with 'Lesart unsicher'</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="if (child::note[@type='commentary']) then replace(., child::note/text(), '') else ' 〈…〉 '"/>
                        <param name="alternate" value="if (child::note[@type='commentary']) then note/text() else 'Lesart unsicher.'"/>
                        <param name="placement" value="'bottom'"/>
                        <param name="fallback-placement" value="'top'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model predicate="@reason='illegible'" behaviour="inline">
                        <desc>If text illegible set〈…〉and put popover with 'Unleserlich'</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="' 〈…〉 '"/>
                        <param name="alternate" value="if (child::note[@type='commentary']) then note/text() else 'Unleserlich.'"/>
                        <param name="placement" value="'bottom'"/>
                        <param name="fallback-placement" value="'top'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                    <model predicate="@reason='unsure'" behaviour="inline">
                        <desc>If text unsure set〈…〉and put popover with 'Unsicher'</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="' 〈…〉 '"/>
                        <param name="alternate" value="'Unsicher.'"/>
                        <param name="placement" value="'bottom'"/>
                        <param name="fallback-placement" value="'top'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                    </model>
                </elementSpec>
                <elementSpec ident="emph" mode="change">
                    <model behaviour="inline" cssClass="annotation annotation-emphasize">
                        <desc>letter spacing</desc>
                        <outputRendition xml:space="preserve">
                            letter-spacing: 3px;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="head" mode="change">
                    <model predicate="$parameters?header='short'" behaviour="inline">
                        <desc>Short title of the document</desc>
                        <param name="content" value="replace(string-join(.//text()[not(parent::ref)]), '^(.*?)[^\w]*$', '$1')"/>
                    </model>
                    <model predicate="parent::table" behaviour="inline" cssClass="italic smaller">
                        <desc>head of a table</desc>
                    </model>
                    <model predicate="parent::list" behaviour="block" cssClass="semibold">
                        <desc>Not in Use. Head of a list.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and following::note[@place='margin-left']" behaviour="block" cssClass="margin-left margin-right">
                        <desc>If there are marginalia right and left after head, set margin to element head.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="block" cssClass="margin-right">
                        <desc>If there are marginalia on the right after head, set margin to element head.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="block" cssClass="margin-left">
                        <desc>If there are marginalia on the left after head, set margin to element head.</desc>
                    </model>
                    <model behaviour="block" cssClass="head">
                        <desc>Default in FPB</desc>
                    </model>
                    <model behaviour="block">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="num" mode="add">
                    <model predicate="child::note" behaviour="inline" cssClass="underlineDotted">
                        <desc>Show note to a number as popover</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="."/>
                        <param name="alternate" value="note/node()"/>
                        <param name="placement" value="'right'"/>
                        <param name="fallback-placement" value="'left'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                        <outputRendition xml:space="preserve">
                            display: flex;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="metamark" mode="add">
                    <model behaviour="inline" cssClass="underlineDotted">
                        <desc>Missing text</desc>
                        <param name="name" value="'pb-popover'"/>
                        <param name="content" value="'......'"/>
                        <param name="alternate" value="'Fehlstelle'"/>
                        <param name="placement" value="'top'"/>
                        <param name="fallback-placement" value="'bottom'"/>
                        <pb:template xmlns="" xml:space="preserve"><pb-popover placement="[[placement]]" fallback-placement="[[fallback-placement]]">[[content]]<span slot="alternate">[[alternate]]</span></pb-popover></pb:template>
                        <outputRendition xml:space="preserve">
                            color: transparent;
                            text-decoration-color: black;
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="gloss" mode="add">
                    <model predicate="@type='margin-right'" behaviour="inline">
                        <desc>Show gloss on the right</desc>
                        <outputRendition xml:space="preserve">                        
                            display: block;
                            float: right;
                            margin-right: -15%;
                            width: 5em;
                            margin-bottom: 0;
                            margin-top: 0;
                            clear: right;
                            overflow: visible;
                            font-size: 70%;
                            text-align: right;
                            text-indent: 0%;                        
                        </outputRendition>
                    </model>
                    <model predicate="@type='margin-left'" behaviour="inline">
                        <desc>Show gloss on the right</desc>
                        <outputRendition xml:space="preserve">                        
                            display: block;
                            float: left;
                            margin-left: -20%;
                            width: 5em;
                            margin-bottom: 0;
                            margin-top: 0;
                            clear: left;
                            overflow: visible;
                            font-size: 70%;
                            text-align: left;
                            text-indent: 0%;                        
                        </outputRendition>
                    </model>
                </elementSpec>
                <elementSpec ident="ab" mode="change">
                    <model predicate="@type='hidden'" behaviour="alternate" cssClass="underlineDotted">
                        <desc>Non-edited text</desc>
                        <param name="default" value="."/>
                        <param name="alternate" value="'Non-edited text / Nicht edierter Text'"/>
                        <outputRendition xml:space="preserve">
                            color: transparent;
                        </outputRendition>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="paragraph" cssClass="margin-left margin-right">
                        <desc>Deprecated. If there are marginalia right and left after ab, set margin to element ab.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="paragraph" cssClass="margin-right">
                        <desc>Deprecated. If there are marginalia on the right after ab, set margin to element ab.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="paragraph" cssClass="margin-left">
                        <desc>Deprecated. If there are marginalia on the left after ab, set margin to element ab.</desc>
                    </model>
                    <model behaviour="inline">
                        <desc>Default</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="table" mode="change">
                    <model predicate="following::note[@place='margin-left'] and following::note[@place='margin-right']" behaviour="table" cssClass="margin-left margin-right table">
                        <desc>If there are marginalia right and left after table, set margin to element table.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-right'] and not(following::note[@place='margin-left'])" behaviour="table" cssClass="margin-right table">
                        <desc>If there are marginalia on the right after table, set margin to element table.</desc>
                    </model>
                    <model predicate="following::note[@place='margin-left'] and not(following::note[@place='margin-right'])" behaviour="table" cssClass="margin-left table">
                        <desc>If there are marginalia on the left after table, set margin to element table.</desc>
                    </model>
                    <model predicate="@rendition='stundenplan'" behaviour="table" cssClass="smaller stundenplan-table">
                        <desc>Table for time tables</desc>
                    </model>
                    <model behaviour="table" cssClass="smaller"/>
                </elementSpec>                        
                <elementSpec ident="cell" mode="change">
                    <model predicate="@role='subheading' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan center">
                        <desc>Subheading for time table cell</desc>
                    </model>
                    <model predicate="@role='subheading'" behaviour="cell" cssClass="italic center">
                        <desc>Subheading for table cell</desc>
                    </model>
                    <model predicate="@role='heading' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan semibold center">
                        <desc>Heading for time table cell</desc>
                    </model>
                    <model predicate="@role='heading'" behaviour="cell" cssClass="semibold center">
                        <desc>Heading for cell</desc>
                    </model>
                    <model predicate="@role='unedited' and @rendition='stundenplan'" behaviour="cell" cssClass="stundenplan center">
                        <desc>Unedited cells for time table</desc>
                        <outputRendition xml:space="preserve">
                            background-color: #e6e6e6;
                        </outputRendition>
                    </model>
                    <model predicate="@role='unedited'" behaviour="cell" cssClass="semibold center">
                        <desc>Unedited cells for table</desc>
                        <outputRendition xml:space="preserve">
                            background-color: #e6e6e6;
                        </outputRendition>
                    </model>
                    <model predicate="@rendition='stundenplan-left-bottom-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-left-hidden stundenplan-bottom-hidden">
                        <desc>Hide left and bottom line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan-left-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-left-hidden">
                    <desc>Hide left line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan-bottom-hidden'" behaviour="cell" cssClass="stundenplan stundenplan-bottom-hidden">
                    <desc>Hide bottom line of time table cell</desc>
                    </model>
                    <model predicate="@rendition='stundenplan'" behaviour="cell" cssClass="stundenplan">
                        <desc>Default for time table cell</desc>
                    </model>
                    <model behaviour="cell">
                    <desc>Default for table cell</desc>
                    </model>
                </elementSpec>
                <elementSpec ident="title" mode="change">
                    <model behaviour="paragraph">
                        <desc>Not in use. Title</desc>
                        <outputRendition xml:space="preserve">
                            font-weight: bold;
                        </outputRendition>
                    </model>
                </elementSpec>
            </schemaSpec>
        </body>
    </text>
</TEI>